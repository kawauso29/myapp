<h1 style="font-size:20px; margin-bottom:20px;">🎨 LINE Stamp Dashboard</h1>

<div class="stats-grid" style="margin-bottom:24px;">
  <div class="stat blue">
    <div class="value"><%= @brands_count %></div>
    <div class="label">Brands</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @packs_count %></div>
    <div class="label">Packs</div>
  </div>
  <div class="stat yellow">
    <div class="value"><%= @stamps_processed %>/<%= @stamps_total %></div>
    <div class="label">Stamps (processed/total)</div>
  </div>
  <div class="stat">
    <div class="value"><%= @submissions_count %></div>
    <div class="label">Submissions</div>
  </div>
</div>

<div class="grid-2">
  <div class="card">
    <h2>Recent Brands</h2>
    <table>
      <thead><tr><th>Name</th><th>Status</th><th>Updated</th></tr></thead>
      <tbody>
        <% @recent_brands.each do |brand| %>
          <tr>
            <td><a href="<%= admin_linestamp_brand_path(brand) %>" style="color:#63b3ed;"><%= brand.character_name %></a></td>
            <td><span class="badge info"><%= brand.status %></span></td>
            <td><%= brand.updated_at.strftime("%Y-%m-%d %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Recent Packs</h2>
    <table>
      <thead><tr><th>Pack</th><th>Brand</th><th>Status</th></tr></thead>
      <tbody>
        <% @recent_packs.each do |pack| %>
          <tr>
            <td><a href="<%= admin_linestamp_pack_path(pack) %>" style="color:#63b3ed;"><%= pack.series_theme %></a></td>
            <td><%= pack.brand.character_name %></td>
            <td><span class="badge info"><%= pack.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div style="margin-top:16px;">
  <a href="<%= admin_linestamp_brands_path %>" class="btn btn-primary">Brands</a>
  <a href="<%= admin_linestamp_packs_path %>" class="btn btn-primary">Packs</a>
  <a href="<%= admin_linestamp_researches_path %>" class="btn btn-primary">Researches</a>
  <a href="<%= admin_linestamp_submissions_path %>" class="btn btn-primary">Submissions</a>
  <a href="<%= admin_linestamp_search_path %>" class="btn btn-primary">Search</a>
</div>

<div class="grid-2" style="margin-top:24px;">
  <div class="card">
    <h2>📊 Sales Analytics</h2>
    <h3>Published Packs: <%= @published_packs_count %></h3>
    <% if @best_sellers.any? %>
      <h4>Top 10 Best Sellers</h4>
      <table>
        <thead><tr><th>Pack</th><th>Brand</th><th>Sales</th></tr></thead>
        <tbody>
          <% @best_sellers.each do |pack| %>
            <tr>
              <td><a href="<%= admin_linestamp_pack_path(pack) %>" style="color:#63b3ed;"><%= pack.series_theme %></a></td>
              <td><%= pack.brand.character_name %></td>
              <td><%= pack.sales_count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <div class="card">
    <h2>🌱 Seed Imports</h2>
    <p>Pending: <strong><%= @pending_seeds_count %></strong></p>
    <p>Failed: <strong style="color:#fc8181;"><%= @failed_seeds_count %></strong></p>
    <% if @failed_seeds.any? %>
      <h4>Recent Failures</h4>
      <table>
        <thead><tr><th>Seed ID</th><th>Error</th><th>Time</th></tr></thead>
        <tbody>
          <% @failed_seeds.each do |sa| %>
            <tr>
              <td><%= sa.seed_id %></td>
              <td><%= truncate(sa.error_message.to_s, length: 80) %></td>
              <td><%= sa.updated_at&.strftime("%Y-%m-%d %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>

<% if @theme_sales.any? %>
<div class="card" style="margin-top:16px;">
  <h2>CT別売上</h2>
  <table>
    <thead><tr><th>Theme</th><th>Total Sales</th></tr></thead>
    <tbody>
      <% @theme_sales.each do |name, total| %>
        <tr><td><%= name %></td><td><%= total %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<% if @attribute_sales.any? %>
<div class="card" style="margin-top:16px;">
  <h2>属性別売上</h2>
  <table>
    <thead><tr><th>Axis / Value</th><th>Total Sales</th></tr></thead>
    <tbody>
      <% @attribute_sales.each do |(axis, value), total| %>
        <tr><td><%= axis %> / <%= value %></td><td><%= total %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>
