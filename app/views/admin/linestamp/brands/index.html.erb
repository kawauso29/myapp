<h1 style="font-size:20px; margin-bottom:20px;">Brands</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Slug</th>
      <th>Status</th>
      <th>Packs</th>
      <th>Updated</th>
    </tr>
  </thead>
  <tbody>
    <% @brands.each do |brand| %>
      <tr>
        <td><a href="<%= admin_linestamp_brand_path(brand) %>" style="color:#63b3ed;"><%= brand.character_name %></a></td>
        <td><code><%= brand.slug %></code></td>
        <td><span class="badge info"><%= brand.status %></span></td>
        <td><%= brand.packs.count %></td>
        <td><%= brand.updated_at.strftime("%Y-%m-%d") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
