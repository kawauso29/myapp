<h1 style="font-size:20px; margin-bottom:20px;"><%= @brand.character_name %></h1>

<div class="grid-2">
  <div class="card">
    <h2>Brand Info</h2>
    <dl class="profile-grid">
      <dt>Slug</dt><dd><code><%= @brand.slug %></code></dd>
      <dt>Status</dt><dd><span class="badge info"><%= @brand.status %></span></dd>
      <dt>起点の調査</dt><dd><%= @brand.research&.slug.presence || "なし" %></dd>
      <dt>Series Name</dt><dd><%= @brand.series_name %></dd>
      <dt>Two-Part Definition</dt><dd><%= @brand.two_part_definition %></dd>
      <dt>Concept</dt><dd><%= @brand.concept %></dd>
      <dt>Target Audience</dt><dd><%= @brand.target_audience %></dd>
      <dt>Primary Color</dt><dd><span style="display:inline-block; width:20px; height:20px; background:<%= @brand.primary_color %>; border:1px solid #555; vertical-align:middle;"></span> <%= @brand.primary_color %></dd>
      <dt>Background Color</dt><dd><span style="display:inline-block; width:20px; height:20px; background:<%= @brand.background_color_for_gen %>; border:1px solid #555; vertical-align:middle;"></span> <%= @brand.background_color_for_gen %></dd>
    </dl>
  </div>

  <div class="card">
    <h2>Base Image</h2>
    <% if @brand.base_image.attached? %>
      <p><%= image_tag url_for(@brand.base_image), style: "max-width:200px; border-radius:8px;" %></p>
      <%= button_to "Remove Base Image", purge_base_admin_linestamp_brand_path(@brand), method: :delete, class: "btn btn-danger btn-sm" %>
    <% else %>
      <p style="color:#718096;">No base image uploaded.</p>
    <% end %>

    <%= form_with url: upload_base_admin_linestamp_brand_path(@brand), method: :post, multipart: true, style: "margin-top:12px;" do |f| %>
      <%= f.file_field :base_image, accept: "image/*", style: "color:#a0aec0;" %>
      <%= f.submit "Upload Base Image", class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>

<% if @brand.character_parts.present? %>
<div class="card" style="margin-top:16px;">
  <h2>Character Parts</h2>
  <dl class="profile-grid">
    <% (@brand.character_parts || {}).each do |part, desc| %>
      <dt><%= part.titleize %></dt><dd><%= desc %></dd>
    <% end %>
  </dl>
</div>
<% end %>

<% if @brand.tone_axes.present? %>
<div class="card" style="margin-top:16px;">
  <h2>Tone Axes</h2>
  <dl class="profile-grid">
    <% (@brand.tone_axes || {}).each do |axis, value| %>
      <dt><%= axis.titleize %></dt>
      <dd>
        <div style="display:flex; align-items:center; gap:8px;">
          <div style="width:100px; height:8px; background:#2d3748; border-radius:4px; overflow:hidden;">
            <div style="width:<%= (value.to_f * 100).round %>%; height:100%; background:#63b3ed;"></div>
          </div>
          <span><%= (value.to_f * 100).round %>%</span>
        </div>
      </dd>
    <% end %>
  </dl>
</div>
<% end %>

<% if @brand.font_spec.present? %>
<div class="card" style="margin-top:16px;">
  <h2>Font Spec</h2>
  <dl class="profile-grid">
    <% (@brand.font_spec || {}).each do |key, val| %>
      <dt><%= key.titleize %></dt><dd><%= val.is_a?(Array) ? val.join(", ") : val %></dd>
    <% end %>
  </dl>
</div>
<% end %>

<div class="card" style="margin-top:16px;">
  <h2>Brand Prompt</h2>
  <% if @brand.brand_prompt.present? %>
    <pre style="background:#232637; padding:12px; border-radius:6px; white-space:pre-wrap; font-size:12px; color:#e2e8f0; max-height:400px; overflow-y:auto;"><%= @brand.brand_prompt %></pre>
    <button onclick="navigator.clipboard.writeText(document.querySelector('pre').textContent)" class="btn btn-primary btn-sm" style="margin-top:8px;">📋 Copy Prompt</button>
  <% else %>
    <p style="color:#718096;">Prompt not yet composed.</p>
  <% end %>
</div>

<div class="card" style="margin-top:16px;">
  <h2>Packs</h2>
  <table>
    <thead><tr><th>#</th><th>Theme</th><th>Layer</th><th>Status</th><th>Stamps</th></tr></thead>
    <tbody>
      <% @brand.packs.order(:position).each do |pack| %>
        <tr>
          <td><%= pack.position %></td>
          <td><a href="<%= admin_linestamp_pack_path(pack) %>" style="color:#63b3ed;"><%= pack.series_theme %></a></td>
          <td><%= pack.layer || "—" %></td>
          <td><span class="badge info"><%= pack.status %></span></td>
          <td><%= pack.stamps.count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# ALL_COLUMNS_DUMP %>
<div class="card" style="margin-top:16px;">
  <h2>全カラム (All Columns)</h2>
  <dl class="profile-grid">
    <% @brand.attributes.each do |__col, __val| %>
      <dt><%= __col %></dt>
      <dd>
        <% if __val.nil? || (__val.respond_to?(:empty?) && __val.empty?) %>
          —
        <% elsif __val.is_a?(Hash) || __val.is_a?(Array) %>
          <pre style="white-space:pre-wrap; font-size:11px; margin:0; background:#232637; padding:8px; border-radius:4px; color:#e2e8f0;"><%= JSON.pretty_generate(__val) %></pre>
        <% else %>
          <%= __val.to_s %>
        <% end %>
      </dd>
    <% end %>
  </dl>
</div>
