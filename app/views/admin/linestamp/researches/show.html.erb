<h1 style="font-size:20px; margin-bottom:20px;"><%= @research.title %></h1>

<div class="card">
  <h2>Research Details</h2>
  <dl class="profile-grid">
    <dt>Status</dt><dd><span class="badge info"><%= @research.status %></span></dd>
    <dt>Source</dt><dd><% if @research.source_url.present? %><%= link_to @research.source_url, URI.parse(@research.source_url).to_s, target: "_blank", rel: "noopener noreferrer", style: "color:#63b3ed;" %><% else %>—<% end %></dd>
    <dt>Created</dt><dd><%= @research.created_at.strftime("%Y-%m-%d %H:%M") %></dd>
  </dl>
</div>

<% if @research.body.present? %>
  <div class="card" style="margin-top:16px;">
    <h2>Body</h2>
    <pre style="background:#232637; padding:12px; border-radius:6px; white-space:pre-wrap; font-size:12px; color:#e2e8f0;"><%= @research.body %></pre>
  </div>
<% end %>
