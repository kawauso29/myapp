<% content_for :title, "LedgerV2 Tickets" %>

<div class="sub-nav">
  <a href="<%= admin_ledger_v2_root_path %>">Dashboard</a>
  <a href="<%= admin_ledger_v2_tickets_path %>" class="current">Tickets</a>
</div>

<%# ===== フラッシュ ===== %>
<% if notice.present? %>
  <div class="card" style="border-color:#48bb78; background:#1a2e1a; margin-bottom:12px; padding:10px 16px;">
    <span style="color:#68d391;"><%= notice %></span>
  </div>
<% end %>
<% if alert.present? %>
  <div class="card" style="border-color:#c53030; background:#2d1515; margin-bottom:12px; padding:10px 16px;">
    <span style="color:#fc8181;"><%= alert %></span>
  </div>
<% end %>

<%# ===== フィルター ===== %>
<div class="card" style="margin-bottom:16px; padding:12px 16px;">
  <%= form_with url: admin_ledger_v2_tickets_path, method: :get, local: true, style: "display:flex; gap:12px; align-items:center; flex-wrap:wrap;" do |f| %>
    <div>
      <label style="color:#a0aec0; font-size:12px; margin-right:6px;">Status</label>
      <%= f.select :status,
            [["すべて", ""],
             ["open", "open"],
             ["in_progress", "in_progress"],
             ["deferred", "deferred"],
             ["resolved", "resolved"],
             ["rejected", "rejected"]],
            {}, { style: "background:#2d3748; color:#e2e8f0; border:1px solid #4a5568; padding:4px 8px;" } %>
    </div>
    <div>
      <label style="color:#a0aec0; font-size:12px; margin-right:6px;">Severity</label>
      <%= f.select :severity,
            [["すべて", ""],
             ["critical", "critical"],
             ["high", "high"],
             ["medium", "medium"],
             ["low", "low"]],
            {}, { style: "background:#2d3748; color:#e2e8f0; border:1px solid #4a5568; padding:4px 8px;" } %>
    </div>
    <%= f.submit "絞り込む", style: "background:#4a5568; color:#e2e8f0; border:none; padding:5px 14px; cursor:pointer;" %>
    <% if @filter_status.present? || @filter_severity.present? %>
      <%= link_to "クリア", admin_ledger_v2_tickets_path, style: "color:#718096; font-size:13px;" %>
    <% end %>
  <% end %>
</div>

<%# ===== Ticket 一覧 ===== %>
<div class="card">
  <h2>Ticket 一覧（最大 50 件）</h2>
  <% if @tickets.empty? %>
    <p style="color:#718096; font-size:13px;">Ticket がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>タイトル</th>
          <th>Severity</th>
          <th>Status</th>
          <th>Review</th>
          <th>Decision</th>
          <th>Metric</th>
          <th>作成日</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @tickets.each do |ticket| %>
          <tr>
            <td style="color:#718096;">#<%= ticket.id %></td>
            <td>
              <div style="font-weight:500;"><%= ticket.title.truncate(60) %></div>
              <% if ticket.description.present? %>
                <div style="color:#718096; font-size:11px;"><%= ticket.description.truncate(80) %></div>
              <% end %>
            </td>
            <td>
              <span style="<%= ticket_severity_style(ticket.severity) %>">
                <%= ticket.severity %>
              </span>
            </td>
            <td style="color:#a0aec0;"><%= ticket.status %></td>
            <td style="color:#a0aec0; font-size:12px;"><%= ticket.review_status %></td>
            <td style="color:#a0aec0; font-size:12px;"><%= ticket.human_decision %></td>
            <td style="color:#718096; font-size:12px;"><%= ticket.metric_name %></td>
            <td style="color:#718096; font-size:12px;">
              <%= ticket.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
            </td>
            <td>
              <%# accept ボタン: open / in_progress / deferred 状態のときのみ表示 %>
              <% if %w[open in_progress deferred].include?(ticket.status) %>
                <%= form_with url: admin_ledger_v2_ticket_path(ticket), method: :patch, local: true, style: "display:inline;" do |f| %>
                  <%= f.hidden_field :review_action, value: "accept" %>
                  <%= f.submit "✓ Accept",
                        style: "background:#276749; color:#68d391; border:none; padding:3px 8px; cursor:pointer; font-size:12px; margin-right:4px;",
                        data: { confirm: "Ticket ##{ticket.id} を accept しますか？" } %>
                <% end %>

                <%# defer ボタン: open / in_progress のみ %>
                <% if %w[open in_progress].include?(ticket.status) %>
                  <%= form_with url: admin_ledger_v2_ticket_path(ticket), method: :patch, local: true, style: "display:inline;" do |f| %>
                    <%= f.hidden_field :review_action, value: "defer" %>
                    <%= f.submit "⏸ Defer",
                          style: "background:#4a3920; color:#f6ad55; border:none; padding:3px 8px; cursor:pointer; font-size:12px; margin-right:4px;",
                          data: { confirm: "Ticket ##{ticket.id} を defer しますか？" } %>
                  <% end %>
                <% end %>

                <%# reject フォーム（理由入力あり） %>
                <details style="display:inline; position:relative;">
                  <summary style="cursor:pointer; color:#fc8181; font-size:12px; display:inline; list-style:none;">✗ Reject</summary>
                  <div style="position:absolute; background:#2d1515; border:1px solid #c53030; padding:12px; z-index:10; min-width:280px; margin-top:4px;">
                    <%= form_with url: admin_ledger_v2_ticket_path(ticket), method: :patch, local: true do |f| %>
                      <%= f.hidden_field :review_action, value: "reject" %>
                      <div style="margin-bottom:8px;">
                        <label style="color:#a0aec0; font-size:12px; display:block; margin-bottom:4px;">却下理由（任意）</label>
                        <%= f.text_area :rejected_reason, rows: 2,
                              style: "width:100%; background:#1a202c; color:#e2e8f0; border:1px solid #4a5568; padding:4px; font-size:12px;" %>
                      </div>
                      <%= f.submit "却下する",
                            style: "background:#c53030; color:#fff; border:none; padding:4px 12px; cursor:pointer; font-size:12px;" %>
                    <% end %>
                  </div>
                </details>
              <% end %>

              <%# reopen ボタン: rejected / deferred のみ %>
              <% if %w[rejected deferred].include?(ticket.status) %>
                <%= form_with url: admin_ledger_v2_ticket_path(ticket), method: :patch, local: true, style: "display:inline;" do |f| %>
                  <%= f.hidden_field :review_action, value: "reopen" %>
                  <%= f.submit "↩ Reopen",
                        style: "background:#2d3748; color:#a0aec0; border:none; padding:3px 8px; cursor:pointer; font-size:12px;",
                        data: { confirm: "Ticket ##{ticket.id} を reopen しますか？" } %>
                <% end %>
              <% end %>

              <% if ticket.rejected_reason.present? %>
                <div style="color:#718096; font-size:11px; margin-top:3px;">理由: <%= ticket.rejected_reason.truncate(40) %></div>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
