<% content_for :title, "LedgerV2 Artifacts" %>

<div class="sub-nav">
  <a href="<%= admin_ledger_v2_root_path %>">Dashboard</a>
  <a href="<%= admin_ledger_v2_tickets_path %>">Tickets</a>
  <a href="<%= admin_ledger_v2_artifacts_path %>" class="current">Artifacts</a>
</div>

<%# ===== フラッシュ ===== %>
<% if notice.present? %>
  <div class="card" style="border-color:#48bb78; background:#1a2e1a; margin-bottom:12px; padding:10px 16px;">
    <span style="color:#68d391;"><%= notice %></span>
  </div>
<% end %>
<% if alert.present? %>
  <div class="card" style="border-color:#c53030; background:#2d1515; margin-bottom:12px; padding:10px 16px;">
    <span style="color:#fc8181;"><%= alert %></span>
  </div>
<% end %>

<%# ===== フィルター ===== %>
<div class="card" style="margin-bottom:16px; padding:12px 16px;">
  <%= form_with url: admin_ledger_v2_artifacts_path, method: :get, local: true, style: "display:flex; gap:12px; align-items:center; flex-wrap:wrap;" do |f| %>
    <div>
      <label style="color:#a0aec0; font-size:12px; margin-right:6px;">Status</label>
      <%= f.select :status,
            [["すべて", ""],
             ["draft", "draft"],
             ["pending", "pending"],
             ["accepted", "accepted"],
             ["review_rejected", "review_rejected"],
             ["review_deferred", "review_deferred"],
             ["needs_more_info", "needs_more_info"],
             ["published", "published"]],
            { selected: @filter_status },
            { style: "background:#2d3748; color:#e2e8f0; border:1px solid #4a5568; padding:4px 8px;" } %>
    </div>
    <div>
      <label style="color:#a0aec0; font-size:12px; margin-right:6px;">Type</label>
      <%= f.select :artifact_type,
            [["すべて", ""],
             ["daily_summary", "daily_summary"],
             ["weekly_review", "weekly_review"],
             ["monthly_review", "monthly_review"],
             ["quarterly_review", "quarterly_review"],
             ["annual_review", "annual_review"],
             ["improvement_proposal", "improvement_proposal"],
             ["anomaly_report", "anomaly_report"],
             ["health_report", "health_report"],
             ["manual_review_note", "manual_review_note"]],
            { selected: @filter_type },
            { style: "background:#2d3748; color:#e2e8f0; border:1px solid #4a5568; padding:4px 8px;" } %>
    </div>
    <%= f.submit "絞り込む", style: "background:#4a5568; color:#e2e8f0; border:none; padding:5px 14px; cursor:pointer;" %>
    <% if @filter_status.present? || @filter_type.present? %>
      <%= link_to "クリア", admin_ledger_v2_artifacts_path, style: "color:#718096; font-size:13px;" %>
    <% end %>
  <% end %>
</div>

<%# ===== Artifact 一覧 ===== %>
<div class="card">
  <h2>Artifact 一覧（最大 50 件）</h2>
  <% if @artifacts.empty? %>
    <p style="color:#718096; font-size:13px;">Artifact がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>タイトル</th>
          <th>Type</th>
          <th>Format</th>
          <th>Status</th>
          <th>レビュー者</th>
          <th>作成日</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @artifacts.each do |artifact| %>
          <tr>
            <td style="color:#718096;">#<%= artifact.id %></td>
            <td>
              <div style="font-weight:500;">
                <%= link_to artifact.title.truncate(60), admin_ledger_v2_artifact_path(artifact),
                      style: "color:#e2e8f0; text-decoration:underline; text-decoration-color:#4a5568;" %>
              </div>
              <% if artifact.body.present? %>
                <div style="color:#718096; font-size:11px;"><%= artifact.body.truncate(80) %></div>
              <% end %>
              <% if artifact.review_comment.present? %>
                <div style="color:#718096; font-size:11px;">コメント: <%= artifact.review_comment.truncate(60) %></div>
              <% end %>
            </td>
            <td style="color:#a0aec0; font-size:12px;"><%= artifact.artifact_type %></td>
            <td style="color:#718096; font-size:12px;"><%= artifact.format %></td>
            <td>
              <span style="<%= artifact_review_status_style(artifact.review_status) %>">
                <%= artifact.review_status %>
              </span>
            </td>
            <td style="color:#718096; font-size:12px;"><%= artifact.reviewed_by.presence || "—" %></td>
            <td style="color:#718096; font-size:12px;">
              <%= artifact.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
            </td>
            <td>
              <%# accept ボタン: draft / pending 状態のときのみ表示 %>
              <% if %w[draft pending].include?(artifact.review_status) %>
                <%= form_with url: admin_ledger_v2_artifact_path(artifact), method: :patch, local: true, style: "display:inline;" do |f| %>
                  <%= f.hidden_field :review_action, value: "accept" %>
                  <%= f.submit "✓ Accept",
                        style: "background:#276749; color:#68d391; border:none; padding:3px 8px; cursor:pointer; font-size:12px; margin-right:4px;",
                        data: { confirm: "Artifact ##{artifact.id} を accept しますか？" } %>
                <% end %>

                <%# defer ボタン %>
                <%= form_with url: admin_ledger_v2_artifact_path(artifact), method: :patch, local: true, style: "display:inline;" do |f| %>
                  <%= f.hidden_field :review_action, value: "defer" %>
                  <%= f.submit "⏸ Defer",
                        style: "background:#4a3920; color:#f6ad55; border:none; padding:3px 8px; cursor:pointer; font-size:12px; margin-right:4px;",
                        data: { confirm: "Artifact ##{artifact.id} を defer しますか？" } %>
                <% end %>

                <%# reject フォーム（コメント入力あり） %>
                <details style="display:inline; position:relative;">
                  <summary style="cursor:pointer; color:#fc8181; font-size:12px; display:inline; list-style:none;">✗ Reject</summary>
                  <div style="position:absolute; background:#2d1515; border:1px solid #c53030; padding:12px; z-index:10; min-width:280px; margin-top:4px;">
                    <%= form_with url: admin_ledger_v2_artifact_path(artifact), method: :patch, local: true do |f| %>
                      <%= f.hidden_field :review_action, value: "reject" %>
                      <div style="margin-bottom:8px;">
                        <label style="color:#a0aec0; font-size:12px; display:block; margin-bottom:4px;">却下理由（任意）</label>
                        <%= f.text_area :review_comment, rows: 2,
                              style: "width:100%; background:#1a202c; color:#e2e8f0; border:1px solid #4a5568; padding:4px; font-size:12px;" %>
                      </div>
                      <%= f.submit "却下する",
                            style: "background:#c53030; color:#fff; border:none; padding:4px 12px; cursor:pointer; font-size:12px;" %>
                    <% end %>
                  </div>
                </details>
              <% end %>

              <%# publish ボタン: accepted 状態のときのみ表示 %>
              <% if artifact.review_status == "accepted" %>
                <%= form_with url: admin_ledger_v2_artifact_path(artifact), method: :patch, local: true, style: "display:inline;" do |f| %>
                  <%= f.hidden_field :review_action, value: "publish" %>
                  <%= f.submit "🚀 Publish",
                        style: "background:#2b4c7e; color:#63b3ed; border:none; padding:3px 8px; cursor:pointer; font-size:12px;",
                        data: { confirm: "Artifact ##{artifact.id} を publish しますか？" } %>
                <% end %>
              <% end %>

              <%# reopen ボタン: rejected / deferred / needs_more_info のみ %>
              <% if %w[review_rejected review_deferred needs_more_info].include?(artifact.review_status) %>
                <%= form_with url: admin_ledger_v2_artifact_path(artifact), method: :patch, local: true, style: "display:inline;" do |f| %>
                  <%= f.hidden_field :review_action, value: "reopen" %>
                  <%= f.submit "↩ Reopen",
                        style: "background:#2d3748; color:#a0aec0; border:none; padding:3px 8px; cursor:pointer; font-size:12px;",
                        data: { confirm: "Artifact ##{artifact.id} を reopen しますか？" } %>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
