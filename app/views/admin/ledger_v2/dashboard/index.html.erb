<% content_for :title, "LedgerV2 Dashboard" %>

<div class="sub-nav">
  <a href="<%= admin_ledger_v2_root_path %>" class="current">Dashboard</a>
  <a href="<%= admin_ledger_v2_tickets_path %>">Tickets</a>
  <a href="<%= admin_ledger_v2_artifacts_path %>">Artifacts</a>
</div>

<%# ===== StopCondition 警告バナー ===== %>
<% if @stop_condition_count > 0 %>
  <div class="card" style="border-color:#c53030; background:#2d1515; margin-bottom:16px;">
    <h2 style="color:#fc8181;">⛔ Active StopCondition: <%= @stop_condition_count %> 件</h2>
    <% @active_stop_conditions.each do |sc| %>
      <div style="margin-top:8px; font-size:13px;">
        <span style="color:#fc8181; font-weight:600;">[<%= sc.severity.upcase %>]</span>
        <span style="color:#e2e8f0;"><%= sc.target_type %> / <%= sc.target_name.presence || "all" %></span>
        &nbsp;—&nbsp;<span style="color:#a0aec0;"><%= sc.reason %></span>
      </div>
    <% end %>
  </div>
<% end %>

<%# ===== v2 卒業判定（7 基準） ===== %>
<div class="card" style="margin-bottom:16px; border-color: <%= @graduation_pass ? '#38a169' : '#4a5568' %>;">
  <h2>
    v2 卒業判定
    <% if @graduation_pass %>
      <span style="color:#68d391;">✅ ALL PASS — Layer C 接続を検討可能</span>
    <% else %>
      <span style="color:#f6e05e;">⏳ 観察継続中（未達基準あり）</span>
    <% end %>
  </h2>
  <p style="color:#a0aec0; font-size:12px; margin-top:4px;">
    しきい値の出典: <code>docs/projects/ledger-v2-migration.md</code> §「v2 卒業基準」
  </p>
  <table style="margin-top:8px;">
    <thead>
      <tr>
        <th>基準</th>
        <th style="text-align:right;">現在値</th>
        <th style="text-align:center;">判定</th>
        <th style="text-align:right;">しきい値</th>
        <th style="text-align:center;">OK</th>
      </tr>
    </thead>
    <tbody>
      <% @graduation_results.each do |r| %>
        <tr>
          <td><%= r.label %></td>
          <td style="text-align:right; font-family:monospace;"><%= r.value %></td>
          <td style="text-align:center; color:#718096;"><%= r.op %></td>
          <td style="text-align:right; font-family:monospace;"><%= r.threshold %></td>
          <td style="text-align:center;">
            <% if r.ok? %>
              <span style="color:#68d391;">✅</span>
            <% else %>
              <span style="color:#fc8181;">❌</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# ===== 統計グリッド ===== %>
<div class="stats-grid" style="margin-bottom:16px;">
  <div class="stat blue">
    <div class="value"><%= @run_stats[:total] %></div>
    <div class="label">Total Runs</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @run_stats[:success] %></div>
    <div class="label">成功</div>
  </div>
  <div class="stat red">
    <div class="value"><%= @run_stats[:failed] %></div>
    <div class="label">失敗</div>
  </div>
  <div class="stat yellow">
    <div class="value"><%= @run_stats[:blocked] %></div>
    <div class="label">Blocked</div>
  </div>
  <div class="stat">
    <div class="value"><%= @run_stats[:dry_run] %></div>
    <div class="label">dry_run</div>
  </div>

  <div class="stat blue">
    <div class="value"><%= @ticket_stats[:open] + @ticket_stats[:in_progress] + @ticket_stats[:deferred] %></div>
    <div class="label">open Tickets</div>
  </div>
  <div class="stat yellow">
    <div class="value"><%= @artifact_stats[:pending] %></div>
    <div class="label">Pending Artifacts</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @duplicate_prevented_total %></div>
    <div class="label">重複防止回数</div>
  </div>
</div>

<%# ===== 直近 Run ===== %>
<div class="card">
  <h2>直近 Run（最新 10 件）</h2>
  <% if @recent_runs.empty? %>
    <p style="color:#718096; font-size:13px;">Run がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Runner</th>
          <th>Status</th>
          <th>dry_run</th>
          <th>Trigger</th>
          <th>Started</th>
          <th>Duration</th>
          <th>Tickets</th>
          <th>Artifacts</th>
          <th>Dup.Prev.</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_runs.each do |run| %>
          <tr>
            <td style="color:#718096;">#<%= run.id %></td>
            <td style="font-weight:600;"><%= run.runner_name %></td>
            <td>
              <span style="<%= run_status_style(run.status) %>">
                <%= run.status %>
              </span>
            </td>
            <td><%= run.dry_run? ? "🔵 dry" : "" %></td>
            <td style="color:#718096;"><%= run.trigger_type %></td>
            <td style="color:#718096; font-size:12px;">
              <%= run.started_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") %>
            </td>
            <td style="color:#718096;">
              <% if run.duration_ms %>
                <%= run.duration_ms %> ms
              <% end %>
            </td>
            <td><%= run.created_ticket_count %></td>
            <td><%= run.created_artifact_count %></td>
            <td><%= run.duplicate_prevented_count %></td>
          </tr>
          <% if run.error_message.present? %>
            <tr>
              <td colspan="10" style="color:#fc8181; font-size:12px; padding:2px 12px 8px;">
                ⚠ <%= run.error_class %>: <%= run.error_message.truncate(120) %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# ===== open Ticket ===== %>
<div class="card">
  <h2>open Ticket（最新 10 件）</h2>
  <% if @open_tickets.empty? %>
    <p style="color:#718096; font-size:13px;">open Ticket がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>タイトル</th>
          <th>Severity</th>
          <th>Status</th>
          <th>Metric</th>
          <th>作成日</th>
        </tr>
      </thead>
      <tbody>
        <% @open_tickets.each do |ticket| %>
          <tr>
            <td style="color:#718096;">#<%= ticket.id %></td>
            <td><%= ticket.title.truncate(50) %></td>
            <td>
              <span style="<%= ticket_severity_style(ticket.severity) %>">
                <%= ticket.severity %>
              </span>
            </td>
            <td style="color:#a0aec0;"><%= ticket.status %></td>
            <td style="color:#718096; font-size:12px;"><%= ticket.metric_name %></td>
            <td style="color:#718096; font-size:12px;">
              <%= ticket.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# ===== Monthly Runner ===== %>
<div class="card" style="margin-top:16px;">
  <h2>
    Monthly Runner
    <% if @monthly_run_stats[:total] == 0 %>
      <span style="color:#718096; font-size:13px; font-weight:400;">（まだ実行されていません）</span>
    <% else %>
      <span style="color:#718096; font-size:13px; font-weight:400;">
        計 <%= @monthly_run_stats[:total] %> 回実行 &nbsp;|&nbsp;
        成功 <%= @monthly_run_stats[:success] %> &nbsp;|&nbsp;
        失敗 <%= @monthly_run_stats[:failed] %> &nbsp;|&nbsp;
        dry_run <%= @monthly_run_stats[:dry_run] %>
      </span>
    <% end %>
  </h2>

  <% if @recent_monthly_runs.empty? %>
    <p style="color:#718096; font-size:13px;">Monthly Run がありません。<code>ledger_v2_monthly_runner</code> フラグが有効になると実行されます。</p>
  <% else %>
    <table style="margin-top:8px;">
      <thead>
        <tr>
          <th>ID</th>
          <th>Status</th>
          <th>dry_run</th>
          <th>Trigger</th>
          <th>Started</th>
          <th>Duration</th>
          <th>Artifacts</th>
          <th>Dup.Prev.</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_monthly_runs.each do |run| %>
          <tr>
            <td style="color:#718096;">#<%= run.id %></td>
            <td>
              <span style="<%= run_status_style(run.status) %>">
                <%= run.status %>
              </span>
            </td>
            <td><%= run.dry_run? ? "🔵 dry" : "" %></td>
            <td style="color:#718096;"><%= run.trigger_type %></td>
            <td style="color:#718096; font-size:12px;">
              <%= run.started_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") %>
            </td>
            <td style="color:#718096;">
              <% if run.duration_ms %>
                <%= run.duration_ms %> ms
              <% end %>
            </td>
            <td><%= run.created_artifact_count %></td>
            <td><%= run.duplicate_prevented_count %></td>
          </tr>
          <% if run.error_message.present? %>
            <tr>
              <td colspan="8" style="color:#fc8181; font-size:12px; padding:2px 12px 8px;">
                ⚠ <%= run.error_class %>: <%= run.error_message.truncate(120) %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <%# Monthly Artifact サマリー %>
  <div style="margin-top:16px; border-top:1px solid #2d3748; padding-top:12px;">
    <h3 style="color:#a0aec0; font-size:13px; margin-bottom:8px;">
      Monthly Artifact
      <span style="font-weight:400; margin-left:8px;">
        計 <%= @monthly_artifact_stats[:total] %> 件 &nbsp;|&nbsp;
        pending <%= @monthly_artifact_stats[:pending] %> &nbsp;|&nbsp;
        accepted <%= @monthly_artifact_stats[:accepted] %>
      </span>
      <% if @monthly_artifact_stats[:total] > 0 %>
        &nbsp;—&nbsp;
        <%= link_to "一覧で確認 →", admin_ledger_v2_artifacts_path(artifact_type: "monthly_review"),
              style: "color:#63b3ed; font-size:12px;" %>
      <% end %>
    </h3>
    <% if @recent_monthly_artifacts.empty? %>
      <p style="color:#718096; font-size:12px;">Monthly Artifact がまだありません。MonthlyRunner が実行されると生成されます。</p>
    <% else %>
      <table style="font-size:12px;">
        <thead>
          <tr>
            <th>ID</th>
            <th>タイトル</th>
            <th>Status</th>
            <th>作成日</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_monthly_artifacts.each do |artifact| %>
            <tr>
              <td style="color:#718096;">#<%= artifact.id %></td>
              <td>
                <%= link_to artifact.title.truncate(60), admin_ledger_v2_artifact_path(artifact),
                      style: "color:#e2e8f0; text-decoration:underline; text-decoration-color:#4a5568;" %>
              </td>
              <td>
                <span style="<%= artifact_review_status_style(artifact.review_status) %>">
                  <%= artifact.review_status %>
                </span>
              </td>
              <td style="color:#718096;">
                <%= artifact.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>

<%# ===== pending Artifact ===== %>
<div class="card">
  <h2>レビュー待ち Artifact（最新 5 件）</h2>
  <% if @pending_artifacts.empty? %>
    <p style="color:#718096; font-size:13px;">レビュー待ち Artifact がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>タイトル</th>
          <th>Type</th>
          <th>Status</th>
          <th>Run</th>
          <th>作成日</th>
        </tr>
      </thead>
      <tbody>
        <% @pending_artifacts.each do |artifact| %>
          <tr>
            <td style="color:#718096;">#<%= artifact.id %></td>
            <td><%= artifact.title.truncate(60) %></td>
            <td style="color:#63b3ed;"><%= artifact.artifact_type %></td>
            <td style="color:#f6e05e;"><%= artifact.review_status %></td>
            <td style="color:#718096;">
              <% if artifact.run_id %>
                Run #<%= artifact.run_id %>
              <% end %>
            </td>
            <td style="color:#718096; font-size:12px;">
              <%= artifact.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
