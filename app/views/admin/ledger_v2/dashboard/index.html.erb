<% content_for :title, "LedgerV2 Dashboard" %>

<div class="sub-nav">
  <a href="<%= admin_ledger_v2_root_path %>" class="current">Dashboard</a>
  <a href="<%= admin_ledger_v2_tickets_path %>">Tickets</a>
</div>

<%# ===== StopCondition 警告バナー ===== %>
<% if @stop_condition_count > 0 %>
  <div class="card" style="border-color:#c53030; background:#2d1515; margin-bottom:16px;">
    <h2 style="color:#fc8181;">⛔ Active StopCondition: <%= @stop_condition_count %> 件</h2>
    <% @active_stop_conditions.each do |sc| %>
      <div style="margin-top:8px; font-size:13px;">
        <span style="color:#fc8181; font-weight:600;">[<%= sc.severity.upcase %>]</span>
        <span style="color:#e2e8f0;"><%= sc.target_type %> / <%= sc.target_name.presence || "all" %></span>
        &nbsp;—&nbsp;<span style="color:#a0aec0;"><%= sc.reason %></span>
      </div>
    <% end %>
  </div>
<% end %>

<%# ===== 統計グリッド ===== %>
<div class="stats-grid" style="margin-bottom:16px;">
  <div class="stat blue">
    <div class="value"><%= @run_stats[:total] %></div>
    <div class="label">Total Runs</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @run_stats[:success] %></div>
    <div class="label">成功</div>
  </div>
  <div class="stat red">
    <div class="value"><%= @run_stats[:failed] %></div>
    <div class="label">失敗</div>
  </div>
  <div class="stat yellow">
    <div class="value"><%= @run_stats[:blocked] %></div>
    <div class="label">Blocked</div>
  </div>
  <div class="stat">
    <div class="value"><%= @run_stats[:dry_run] %></div>
    <div class="label">dry_run</div>
  </div>

  <div class="stat blue">
    <div class="value"><%= @ticket_stats[:open] + @ticket_stats[:in_progress] + @ticket_stats[:deferred] %></div>
    <div class="label">open Tickets</div>
  </div>
  <div class="stat yellow">
    <div class="value"><%= @artifact_stats[:pending] %></div>
    <div class="label">Pending Artifacts</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @duplicate_prevented_total %></div>
    <div class="label">重複防止回数</div>
  </div>
</div>

<%# ===== 直近 Run ===== %>
<div class="card">
  <h2>直近 Run（最新 10 件）</h2>
  <% if @recent_runs.empty? %>
    <p style="color:#718096; font-size:13px;">Run がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Runner</th>
          <th>Status</th>
          <th>dry_run</th>
          <th>Trigger</th>
          <th>Started</th>
          <th>Duration</th>
          <th>Tickets</th>
          <th>Artifacts</th>
          <th>Dup.Prev.</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_runs.each do |run| %>
          <tr>
            <td style="color:#718096;">#<%= run.id %></td>
            <td style="font-weight:600;"><%= run.runner_name %></td>
            <td>
              <span style="<%= run_status_style(run.status) %>">
                <%= run.status %>
              </span>
            </td>
            <td><%= run.dry_run? ? "🔵 dry" : "" %></td>
            <td style="color:#718096;"><%= run.trigger_type %></td>
            <td style="color:#718096; font-size:12px;">
              <%= run.started_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") %>
            </td>
            <td style="color:#718096;">
              <% if run.duration_ms %>
                <%= run.duration_ms %> ms
              <% end %>
            </td>
            <td><%= run.created_ticket_count %></td>
            <td><%= run.created_artifact_count %></td>
            <td><%= run.duplicate_prevented_count %></td>
          </tr>
          <% if run.error_message.present? %>
            <tr>
              <td colspan="10" style="color:#fc8181; font-size:12px; padding:2px 12px 8px;">
                ⚠ <%= run.error_class %>: <%= run.error_message.truncate(120) %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# ===== open Ticket ===== %>
<div class="card">
  <h2>open Ticket（最新 10 件）</h2>
  <% if @open_tickets.empty? %>
    <p style="color:#718096; font-size:13px;">open Ticket がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>タイトル</th>
          <th>Severity</th>
          <th>Status</th>
          <th>Metric</th>
          <th>作成日</th>
        </tr>
      </thead>
      <tbody>
        <% @open_tickets.each do |ticket| %>
          <tr>
            <td style="color:#718096;">#<%= ticket.id %></td>
            <td><%= ticket.title.truncate(50) %></td>
            <td>
              <span style="<%= ticket_severity_style(ticket.severity) %>">
                <%= ticket.severity %>
              </span>
            </td>
            <td style="color:#a0aec0;"><%= ticket.status %></td>
            <td style="color:#718096; font-size:12px;"><%= ticket.metric_name %></td>
            <td style="color:#718096; font-size:12px;">
              <%= ticket.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# ===== pending Artifact ===== %>
<div class="card">
  <h2>レビュー待ち Artifact（最新 5 件）</h2>
  <% if @pending_artifacts.empty? %>
    <p style="color:#718096; font-size:13px;">レビュー待ち Artifact がありません。</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>タイトル</th>
          <th>Type</th>
          <th>Status</th>
          <th>Run</th>
          <th>作成日</th>
        </tr>
      </thead>
      <tbody>
        <% @pending_artifacts.each do |artifact| %>
          <tr>
            <td style="color:#718096;">#<%= artifact.id %></td>
            <td><%= artifact.title.truncate(60) %></td>
            <td style="color:#63b3ed;"><%= artifact.artifact_type %></td>
            <td style="color:#f6e05e;"><%= artifact.review_status %></td>
            <td style="color:#718096;">
              <% if artifact.run_id %>
                Run #<%= artifact.run_id %>
              <% end %>
            </td>
            <td style="color:#718096; font-size:12px;">
              <%= artifact.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
