<% content_for :title, "AI SNS 開発施策管理" %>

<div class="sub-nav">
  <a href="<%= admin_ai_sns_path %>">AI SNS</a>
  <a href="<%= admin_dev_initiatives_path %>" class="current">開発施策</a>
</div>

<%# ===== 統計カード ===== %>
<div class="stats-grid" style="margin-bottom:16px;">
  <div class="stat">
    <div class="value"><%= @stats[:todo] %></div>
    <div class="label">Todo</div>
  </div>
  <div class="stat blue">
    <div class="value"><%= @stats[:in_progress] %></div>
    <div class="label">In Progress</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @stats[:done] %></div>
    <div class="label">Done</div>
  </div>
  <div class="stat">
    <div class="value"><%= @stats[:total] %></div>
    <div class="label">Total</div>
  </div>
</div>

<%# ===== フラッシュ ===== %>
<% if notice %>
  <div style="background:#276749;color:#c6f6d5;padding:8px 12px;border-radius:4px;margin-bottom:12px;"><%= notice %></div>
<% end %>
<% if alert %>
  <div style="background:#742a2a;color:#fed7d7;padding:8px 12px;border-radius:4px;margin-bottom:12px;"><%= alert %></div>
<% end %>

<%# ===== 施策一覧（PR2: 正本は TicketLedger.ai_sns_plan） ===== %>
<%
  # TicketLedger の status enum 値 → 表示用ラベル / クラス
  ledger_status_label = { "draft" => "todo", "executing" => "in_progress", "completed" => "done" }
  ledger_status_color = { "draft" => "#718096", "executing" => "#4299e1", "completed" => "#48bb78" }
  ledger_priority_label = { "high" => "★★★", "medium" => "★★☆", "low" => "★☆☆" }
%>
<div class="card">
  <h2>施策一覧（WIP上限: 2）</h2>
  <table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead>
      <tr style="border-bottom:1px solid #2d3748;text-align:left;">
        <th style="padding:6px 8px;">ID</th>
        <th style="padding:6px 8px;">タイトル</th>
        <th style="padding:6px 8px;">カテゴリ</th>
        <th style="padding:6px 8px;">優先度</th>
        <th style="padding:6px 8px;">ステータス</th>
        <th style="padding:6px 8px;">最終更新</th>
        <th style="padding:6px 8px;">完了日</th>
        <th style="padding:6px 8px;">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @tickets.each do |t| %>
        <% item_key = t.ai_sns_plan_item_key %>
        <% disp_status = ledger_status_label[t.status] || t.status %>
        <% status_color = ledger_status_color[t.status] || "#718096" %>
        <% priority_label = ledger_priority_label[t.priority] || t.priority %>
        <tr style="border-bottom:1px solid #2d3748;">
          <td style="padding:6px 8px;font-weight:bold;color:#90cdf4;"><%= item_key %></td>
          <td style="padding:6px 8px;max-width:280px;">
            <%= t.title %>
            <% if t.pr_branch.present? %>
              <br><small style="color:#718096;"><%= t.pr_branch %></small>
            <% end %>
          </td>
          <td style="padding:6px 8px;color:#a0aec0;"><%= t.improvement_pattern_key %></td>
          <td style="padding:6px 8px;"><%= priority_label %></td>
          <td style="padding:6px 8px;">
            <span style="color:<%= status_color %>;font-weight:bold;"><%= disp_status %></span>
          </td>
          <td style="padding:6px 8px;color:#a0aec0;font-size:11px;">
            <%= t.updated_at&.in_time_zone("Tokyo")&.strftime("%m/%d") || "-" %>
          </td>
          <td style="padding:6px 8px;color:#a0aec0;font-size:11px;">
            <%= (t.status_completed? ? t.updated_at&.in_time_zone("Tokyo")&.strftime("%m/%d") : nil) || "-" %>
          </td>
          <td style="padding:6px 8px;">
            <div style="display:flex;gap:4px;flex-wrap:wrap;">
              <% unless t.status_draft? %>
                <%= button_to "todo", update_status_admin_dev_initiative_path(item_key), params: { status: "todo" }, method: :patch, style: "font-size:11px;padding:2px 6px;background:#4a5568;color:#e2e8f0;border:none;border-radius:3px;cursor:pointer;" %>
              <% end %>
              <% unless t.status_executing? %>
                <%= button_to "WIP▶", update_status_admin_dev_initiative_path(item_key), params: { status: "in_progress" }, method: :patch, style: "font-size:11px;padding:2px 6px;background:#2b6cb0;color:#bee3f8;border:none;border-radius:3px;cursor:pointer;" %>
              <% end %>
              <% unless t.status_completed? %>
                <%= button_to "done✓", update_status_admin_dev_initiative_path(item_key), params: { status: "done" }, method: :patch, style: "font-size:11px;padding:2px 6px;background:#276749;color:#c6f6d5;border:none;border-radius:3px;cursor:pointer;" %>
              <% end %>
            </div>
          </td>
        </tr>
        <% legacy_notes = Admin::AiSnsPlanService.legacy_notes_for(item_key) %>
        <% if t.kpi_hypothesis.present? || t.kpi_result.present? || legacy_notes.present? %>
          <tr style="border-bottom:1px solid #1a202c;">
            <td colspan="8" style="padding:4px 8px 8px 28px;color:#718096;font-size:11px;">
              <% if t.kpi_hypothesis.present? %>
                <span style="color:#f6ad55;">KPI仮説:</span> <%= t.kpi_hypothesis %>&nbsp;&nbsp;
              <% end %>
              <% if t.kpi_result.present? %>
                <span style="color:#68d391;">KPI結果:</span> <%= t.kpi_result %>&nbsp;&nbsp;
              <% end %>
              <% if legacy_notes.present? %>
                <span style="color:#90cdf4;">備考:</span> <%= legacy_notes %>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
