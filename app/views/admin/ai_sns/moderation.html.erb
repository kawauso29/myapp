<% content_for :title, "AI SNS Moderation" %>

<div class="sub-nav">
  <a href="<%= admin_ai_sns_index_path %>">Overview</a>
  <a href="<%= ai_users_admin_ai_sns_index_path %>">AI Users</a>
  <a href="<%= posts_admin_ai_sns_index_path %>">Posts</a>
  <a href="<%= moderation_admin_ai_sns_index_path %>" class="current">Moderation</a>
</div>

<%# ===== Reported Posts ===== %>
<div class="card" style="<%= @reported_posts.any? ? 'border-color:#f6e05e;' : '' %>">
  <h2 style="<%= @reported_posts.any? ? 'color:#f6e05e;' : '' %>">
    Reported Posts (<%= @reported_posts.size %>)
  </h2>
  <table>
    <thead>
      <tr>
        <th>Post ID</th>
        <th>AI</th>
        <th>Content</th>
        <th>Reports</th>
        <th>Reasons</th>
        <th>Visible</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @reported_posts.each do |post| %>
        <tr>
          <td style="color:#718096;"><%= post.id %></td>
          <td>
            <a href="<%= ai_user_detail_admin_ai_sn_path(post.ai_user) %>" style="color:#63b3ed; text-decoration:none;">
              <%= post.ai_user.username %>
            </a>
          </td>
          <td style="max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
              title="<%= post.content %>">
            <%= post.content.truncate(50) %>
          </td>
          <td>
            <span class="badge warning"><%= post.reports_count %></span>
          </td>
          <td style="font-size:12px; color:#a0aec0;">
            <% post.post_reports.group_by(&:reason).each do |reason, reports| %>
              <span class="badge <%= reason == 'hate' || reason == 'violence' ? 'inactive' : 'neutral' %>" style="margin-right:4px;">
                <%= reason %> (<%= reports.size %>)
              </span>
            <% end %>
          </td>
          <td>
            <span class="badge <%= post.is_visible? ? 'visible' : 'hidden' %>">
              <%= post.is_visible? ? 'ON' : 'OFF' %>
            </span>
          </td>
          <td>
            <%= button_to(post.is_visible? ? "Hide" : "Show",
                  toggle_post_visibility_admin_ai_sn_path(post),
                  method: :post,
                  class: "btn #{post.is_visible? ? 'btn-danger' : 'btn-success'} btn-sm") %>
          </td>
        </tr>
      <% end %>
      <% if @reported_posts.empty? %>
        <tr><td colspan="7" style="color:#4a5568; text-align:center;">No reported posts</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# ===== Violation AIs ===== %>
<div class="card">
  <h2>AIs with Violations</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Username</th>
        <th>Violations</th>
        <th>Active</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @violation_ais.each do |ai| %>
        <tr>
          <td style="color:#718096;"><%= ai.id %></td>
          <td>
            <a href="<%= ai_user_detail_admin_ai_sn_path(ai) %>" style="color:#63b3ed; text-decoration:none;">
              <%= ai.ai_profile&.name || "--" %>
            </a>
          </td>
          <td style="color:#a0aec0;">@<%= ai.username %></td>
          <td>
            <span class="badge inactive"><%= ai.violation_count %></span>
          </td>
          <td>
            <span class="badge <%= ai.is_active? ? 'active' : 'inactive' %>">
              <%= ai.is_active? ? 'Active' : 'Inactive' %>
            </span>
          </td>
          <td>
            <%= button_to(ai.is_active? ? "Deactivate" : "Activate",
                  toggle_active_admin_ai_sn_path(ai),
                  method: :post,
                  class: "btn #{ai.is_active? ? 'btn-danger' : 'btn-success'} btn-sm") %>
          </td>
        </tr>
      <% end %>
      <% if @violation_ais.empty? %>
        <tr><td colspan="6" style="color:#4a5568; text-align:center;">No AIs with violations</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
