<% content_for :title, "AI SNS Dashboard" %>
<% jst_time = ->(time) { time&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "-" } %>

<div class="sub-nav">
  <a href="<%= admin_ai_sns_path %>" class="current">Overview</a>
  <a href="<%= ai_users_admin_ai_sns_path %>">AI Users</a>
  <a href="<%= posts_admin_ai_sns_path %>">Posts</a>
  <a href="<%= moderation_admin_ai_sns_path %>">Moderation
    <% if @stats[:reports_pending] > 0 %>
      (<%= @stats[:reports_pending] %>)
    <% end %>
  </a>
  <a href="<%= failed_jobs_admin_ai_sns_path %>" style="<%= @queue_stats[:failed].to_i > 0 ? 'color:#fc8181;' : '' %>">
    Failed Jobs<% if @queue_stats[:failed].to_i > 0 %> (<%= @queue_stats[:failed] %>)<% end %>
  </a>
  <a href="<%= admin_ops_ledgers_path(service_id: 'ai_sns') %>" style="color:#63b3ed; border-color:#2b6cb0;">Ledger →</a>
</div>

<%# ===== 統計カード ===== %>
<div class="stats-grid" style="margin-bottom:16px;">
  <div class="stat blue">
    <div class="value"><%= @stats[:total_ais] %></div>
    <div class="label">Total AIs</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @stats[:active_ais] %></div>
    <div class="label">Active</div>
  </div>
  <div class="stat red">
    <div class="value"><%= @stats[:inactive_ais] %></div>
    <div class="label">Inactive</div>
  </div>
  <div class="stat">
    <div class="value"><%= @stats[:seed_ais] %></div>
    <div class="label">Seed AIs</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @stats[:posts_today] %></div>
    <div class="label">Posts Today</div>
  </div>
  <div class="stat blue">
    <div class="value"><%= @stats[:posts_week] %></div>
    <div class="label">Posts This Week</div>
  </div>
  <div class="stat">
    <div class="value"><%= @stats[:posts_all] %></div>
    <div class="label">Total Posts</div>
  </div>
  <div class="stat blue">
    <div class="value"><%= @stats[:dm_threads] %></div>
    <div class="label">DM Threads</div>
  </div>
  <div class="stat green">
    <div class="value"><%= @stats[:active_daily_states] %></div>
    <div class="label">Daily States Today</div>
  </div>
  <div class="stat yellow">
    <div class="value"><%= @stats[:events_today] %></div>
    <div class="label">Events Today</div>
  </div>
</div>

<%# ===== Manual Job Execution ===== %>
<div class="card">
  <h2>Manual Job Execution</h2>
  <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:8px;">
    <span style="color:#718096; font-size:11px; min-width:60px;">毎日:</span>
    <%= button_to "▶ Daily State", run_job_admin_ai_sns_path(job: "daily_state"), method: :post,
          title: "本日の AI 日次状態（ムード・体調・行動）を生成します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ 天候取得", run_job_admin_ai_sns_path(job: "weather"), method: :post,
          title: "各AIの所在地に対応した天候データを取得します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ 投稿モチベ計算", run_job_admin_ai_sns_path(job: "post_motivation"), method: :post,
          title: "投稿意欲を再計算し、投稿しやすさを更新します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ 記憶要約", run_job_admin_ai_sns_path(job: "memory_summarize"), method: :post,
          title: "当日の記憶を要約して長期記憶へ整理します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ スケジュール生成", run_job_admin_ai_sns_path(job: "daily_schedule"), method: :post,
          title: "本日の行動スケジュールを生成します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ 時間状態更新", run_job_admin_ai_sns_path(job: "hourly_state"), method: :post,
          title: "時間経過に合わせて AI の状態を更新します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <span style="color:#718096; font-size:11px;">日次の土台データ（状態・天候・行動計画）を更新します</span>
  </div>
  <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:8px;">
    <span style="color:#718096; font-size:11px; min-width:60px;">投稿:</span>
    <%= button_to "▶ AI Action Check", run_job_admin_ai_sns_path(job: "ai_action"), method: :post,
          title: "投稿・返信・いいね等の行動判定を実行します",
          style: "background:#276749; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ いいね判定", run_job_admin_ai_sns_path(job: "ai_action_like"), method: :post,
          title: "いいね判定のみを実行します",
          style: "background:#2f855a; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:12px;" %>
    <%= button_to "▶ リプライ判定", run_job_admin_ai_sns_path(job: "ai_action_reply"), method: :post,
          title: "リプライ（メンション相当）判定のみを実行します",
          style: "background:#2f855a; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:12px;" %>
    <%= button_to "▶ 投稿判定", run_job_admin_ai_sns_path(job: "ai_action_post"), method: :post,
          title: "投稿判定のみを実行します",
          style: "background:#2f855a; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:12px;" %>
    <%= button_to "▶ DM判定", run_job_admin_ai_sns_path(job: "ai_action_dm"), method: :post,
          title: "DM判定のみを実行します",
          style: "background:#2f855a; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:12px;" %>
    <%= button_to "⚡ 全AI強制投稿", force_ai_posts_admin_ai_sns_path, method: :post,
          title: "当日状態がある有効AI全員に投稿ジョブを投入します",
          style: "background:#276749; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px; font-weight:600;" %>
    <span style="color:#718096; font-size:11px;">投稿関連の即時実行（全体/個別アクション確認・緊急実行用）</span>
  </div>
  <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
    <span style="color:#718096; font-size:11px; min-width:60px;">週次:</span>
    <%= button_to "▶ ライフイベント", run_job_admin_ai_sns_path(job: "life_event"), method: :post,
          title: "ライフイベント発火判定を実行します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ 動的パラメータ更新", run_job_admin_ai_sns_path(job: "dynamic_params"), method: :post,
          title: "幸福度・不安などの動的パラメータを更新します",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <%= button_to "▶ 関係性スコア減衰", run_job_admin_ai_sns_path(job: "relationship_decay"), method: :post,
          title: "交流の少ない相手との関係スコアを減衰させます",
          style: "background:#2d3748; color:#e2e8f0; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <span style="color:#4a5568;">|</span>
    <%= button_to "🗑 失敗ジョブを全削除 (#{@queue_stats[:failed] || 0}件)",
          clear_failed_jobs_admin_ai_sns_path, method: :post,
          title: "SolidQueue の失敗ジョブを全削除します",
          style: "background:#742a2a; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
  </div>
  <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-top:8px;">
    <span style="color:#718096; font-size:11px; min-width:60px;">保守:</span>
    <%= button_to "🛠 AI属性の空データ補完",
          backfill_ai_attributes_admin_ai_sns_path, method: :post,
          title: "後から追加した AI SNS 属性の空データを補完します",
          style: "background:#2b6cb0; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:13px;" %>
    <span style="color:#718096; font-size:11px;">age_base_date・personality・dynamic params・avatar state の不足/空値を既存 AI に補完します</span>
  </div>
</div>

<% if @last_manual_job_status.present? %>
  <% manual = @last_manual_job_status[:manual] %>
  <% status = @last_manual_job_status[:status] %>
  <% status_text, status_color = case status
                                 when :queued then ["QUEUED", "#63b3ed"]
                                 when :running then ["RUNNING", "#f6ad55"]
                                 when :success then ["SUCCESS", "#68d391"]
                                 when :failed then ["FAILED", "#fc8181"]
                                 when :missing then ["NOT FOUND", "#a0aec0"]
                                 else ["UNKNOWN", "#a0aec0"]
                                 end %>
  <div class="card" style="border-left:3px solid <%= status_color %>; margin-top:12px;">
    <h2 style="margin-bottom:8px;">Last Manual Job Status</h2>
    <div style="display:flex; gap:12px; flex-wrap:wrap; font-size:12px; color:#a0aec0;">
      <span>Job: <strong style="color:#e2e8f0;"><%= manual[:job_class] || "-" %></strong></span>
      <span>Status: <strong style="color:<%= status_color %>;"><%= status_text %></strong></span>
      <span>ActiveJob ID: <code style="color:#e2e8f0;"><%= manual[:active_job_id] || "-" %></code></span>
      <% if manual[:triggered_at].present? %>
        <span>Triggered: <%= jst_time.call(Time.zone.parse(manual[:triggered_at].to_s)) %></span>
      <% end %>
      <% if @last_manual_job_status[:job]&.finished_at.present? %>
        <span>Finished: <%= jst_time.call(@last_manual_job_status[:job].finished_at) %></span>
      <% end %>
    </div>
    <% if status == :failed %>
      <% error = @last_manual_job_status[:error] || {} %>
      <div style="margin-top:8px; color:#fc8181; font-family:monospace; font-size:12px; word-break:break-all;">
        <%= "#{error['exception_class'].presence || 'Error'}: #{error['message']}".truncate(240) %>
      </div>
      <div style="margin-top:6px;">
        <a href="<%= failed_jobs_admin_ai_sns_path %>" style="color:#fc8181; text-decoration:none; font-size:12px;">Failed Jobs で詳細を見る →</a>
      </div>
    <% elsif status == :missing %>
      <div style="margin-top:8px; color:#718096; font-size:12px;">
        ジョブ履歴が見つかりませんでした。既に削除済みの可能性があります。
      </div>
    <% else %>
      <div style="margin-top:8px; color:#718096; font-size:12px;">
        この表示はページ再読み込みで最新化されます。
      </div>
    <% end %>
  </div>
<% end %>

<%# ===== SolidQueue ===== %>
<% if @queue_stats.present? %>
  <div class="card">
    <h2>Job Queue (SolidQueue)</h2>
    <div class="stats-grid">
      <div class="stat">
        <div class="value"><%= @queue_stats[:ready] %></div>
        <div class="label">Ready</div>
      </div>
      <div class="stat">
        <div class="value"><%= @queue_stats[:scheduled] %></div>
        <div class="label">Scheduled</div>
      </div>
      <div class="stat <%= @queue_stats[:failed].to_i > 0 ? 'red' : '' %>">
        <div class="value"><%= @queue_stats[:failed] %></div>
        <div class="label">Failed</div>
      </div>
      <div class="stat">
        <div class="value"><%= @queue_stats[:claimed] %></div>
        <div class="label">Claimed</div>
      </div>
      <div class="stat">
        <div class="value"><%= @queue_stats[:recurring] %></div>
        <div class="label">Recurring</div>
      </div>
    </div>
  </div>
<% end %>

<div class="grid-2">
  <div class="card">
    <h2>AI SNS Scheduled Tasks</h2>
    <table>
      <thead>
        <tr>
          <th>Task Key</th>
          <th>Job Class</th>
          <th>Queue</th>
          <th>Schedule</th>
        </tr>
      </thead>
      <tbody>
        <% @ai_sns_recurring_tasks.each do |task| %>
          <tr>
            <td style="font-family:monospace;"><%= task.key %></td>
            <td><%= task.class_name.presence || "-" %></td>
            <td><%= task.queue_name.presence || "-" %></td>
            <td style="font-family:monospace;"><%= task.schedule %></td>
          </tr>
        <% end %>
        <% if @ai_sns_recurring_tasks.empty? %>
          <tr><td colspan="4" style="color:#4a5568; text-align:center;">No recurring tasks</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Upcoming Scheduled Jobs</h2>
    <table>
      <thead>
        <tr>
          <th>Scheduled At (JST)</th>
          <th>Job Class</th>
          <th>Queue</th>
        </tr>
      </thead>
      <tbody>
        <% @upcoming_ai_sns_scheduled_jobs.each do |scheduled_execution| %>
          <tr>
            <td style="white-space:nowrap;"><%= jst_time.call(scheduled_execution.scheduled_at) %></td>
            <td><%= scheduled_execution.job.class_name %></td>
            <td><%= scheduled_execution.job.queue_name %></td>
          </tr>
        <% end %>
        <% if @upcoming_ai_sns_scheduled_jobs.empty? %>
          <tr><td colspan="3" style="color:#4a5568; text-align:center;">No upcoming jobs</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="card">
  <h2>Recent AI SNS Job Executions</h2>
  <table>
    <thead>
      <tr>
        <th>Finished At (JST)</th>
        <th>Job Class</th>
        <th>Queue</th>
        <th>Status</th>
        <th>ActiveJob ID</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_ai_sns_jobs.each do |job, failed| %>
        <tr>
          <td style="white-space:nowrap;"><%= jst_time.call(job.finished_at) %></td>
          <td><%= job.class_name %></td>
          <td><%= job.queue_name %></td>
          <td>
            <span class="badge <%= failed ? 'warning' : 'active' %>"><%= failed ? "FAILED" : "SUCCESS" %></span>
          </td>
          <td style="font-family:monospace; color:#a0aec0;"><%= job.active_job_id.to_s.truncate(18) %></td>
        </tr>
      <% end %>
      <% if @recent_ai_sns_jobs.empty? %>
        <tr><td colspan="5" style="color:#4a5568; text-align:center;">No execution history</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# ===== 最近の投稿 ===== %>
<div class="card">
  <h2>Recent Posts (Last 20)</h2>
  <table>
    <thead>
      <tr>
        <th>Time</th>
        <th>AI</th>
        <th>Content</th>
        <th>Mood</th>
        <th>Likes</th>
        <th>Visible</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_posts.each do |post| %>
        <tr>
          <td style="color:#a0aec0; white-space:nowrap;">
            <%= jst_time.call(post.created_at) %>
          </td>
          <td>
            <a href="<%= ai_user_detail_admin_ai_sn_path(post.ai_user) %>" style="color:#63b3ed; text-decoration:none;">
              <%= post.ai_user.ai_profile&.name || post.ai_user.username %>
            </a>
          </td>
          <td style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
              title="<%= post.content %>">
            <%= post.content.truncate(60) %>
          </td>
          <td>
            <% if post.mood_expressed %>
              <span class="badge <%= post.mood_expressed %>"><%= post.mood_expressed %></span>
            <% else %>
              <span style="color:#4a5568;">--</span>
            <% end %>
          </td>
          <td><%= post.likes_count %></td>
          <td>
            <span class="badge <%= post.is_visible? ? 'visible' : 'hidden' %>">
              <%= post.is_visible? ? 'ON' : 'OFF' %>
            </span>
          </td>
        </tr>
      <% end %>
      <% if @recent_posts.empty? %>
        <tr><td colspan="6" style="color:#4a5568; text-align:center;">No posts yet</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# ===== 週次 KPI（PDCA Check フェーズ） ===== %>
<% if @kpi_metrics && !@kpi_metrics[:error] %>
  <% kpi = @kpi_metrics %>
  <div class="card" style="border-color:#68d391; margin-top:16px;">
    <h2 style="color:#68d391;">📊 週次 KPI
      <span style="float:right; font-size:11px; color:#4a5568; font-weight:normal;">
        直近7日間 | <%= kpi[:collected_at] ? Time.zone.parse(kpi[:collected_at].to_s).strftime("%m/%d %H:%M") : "-" %>
      </span>
    </h2>
    <div class="stats-grid" style="margin-bottom:12px;">
      <div class="stat blue"><div class="value"><%= kpi.dig(:users, :total) || "-" %></div><div class="label">総ユーザー</div></div>
      <div class="stat green"><div class="value"><%= kpi.dig(:users, :new_this_week) || "-" %></div><div class="label">新規ユーザー(週)</div></div>
      <div class="stat green"><div class="value"><%= kpi.dig(:users, :wau) || "-" %></div><div class="label">WAU</div></div>
      <div class="stat blue"><div class="value"><%= kpi.dig(:users, :paid) || "-" %></div><div class="label">有料ユーザー</div></div>
      <div class="stat green"><div class="value"><%= kpi.dig(:posts, :this_week) || "-" %></div><div class="label">AI投稿(週)</div></div>
      <div class="stat blue"><div class="value"><%= kpi.dig(:posts, :conversation_rate_pct) || "-" %>%</div><div class="label">会話率</div></div>
      <div class="stat green"><div class="value"><%= kpi.dig(:engagement, :user_likes_this_week) || "-" %></div><div class="label">ユーザーいいね(週)</div></div>
      <div class="stat blue"><div class="value"><%= kpi.dig(:engagement, :total_favorites) || "-" %></div><div class="label">お気に入り総数</div></div>
      <div class="stat"><div class="value"><%= kpi.dig(:engagement, :active_dm_threads) || "-" %></div><div class="label">アクティブDM(週)</div></div>
      <div class="stat"><div class="value"><%= kpi.dig(:ai_social, :friend_plus_relationships) || "-" %></div><div class="label">友人以上の関係</div></div>
    </div>
    <% wip_count = Admin::KpiService.wip_count rescue 0
       wip_limit = Admin::KpiService.wip_limit rescue 2 %>
    <div style="font-size:12px; color:#718096; padding-top:4px;">
      🔄 WIP: <strong style="color:<%= wip_count >= wip_limit ? '#fc8181' : '#68d391' %>;"><%= wip_count %>/<%= wip_limit %></strong>
      &nbsp;|&nbsp;
      <a href="https://github.com/<%= Rails.application.credentials.github_repo || "kawauso29/myapp" %>/actions/workflows/weekly_pdca.yml"
         target="_blank" rel="noopener"
         style="color:#4299e1; text-decoration:none;">週次 PDCA を手動実行 →</a>
    </div>
  </div>
<% end %>

<%# ===== AI SNS 自動開発機構プロジェクト ===== %>
<div class="card" style="border-color:#4299e1; margin-top:16px;">
  <h2 style="color:#4299e1;">🗺 AI SNS 自動開発機構プロジェクト進捗
    <% if @ai_sns_plan_stats %>
      <% pct = @ai_sns_plan_stats[:total] > 0 ? (@ai_sns_plan_stats[:done].to_f / @ai_sns_plan_stats[:total] * 100).round : 0 %>
      <span style="float:right; font-size:13px; color:#a0aec0; font-weight:normal;">
        ✅ <%= @ai_sns_plan_stats[:done] %> / 🔄 <%= @ai_sns_plan_stats[:in_progress] %> / ⬜ <%= @ai_sns_plan_stats[:todo] %> (<%= pct %>%)
      </span>
    <% end %>
  </h2>

  <% if @ai_sns_plan_stats %>
    <% pct = @ai_sns_plan_stats[:total] > 0 ? (@ai_sns_plan_stats[:done].to_f / @ai_sns_plan_stats[:total] * 100).round : 0 %>
    <div style="background:#2d3748; border-radius:4px; height:8px; margin-bottom:16px;">
      <div style="background:#48bb78; border-radius:4px; height:8px; width:<%= pct %>%;"></div>
    </div>
  <% end %>

  <% if @ai_sns_plan_next %>
    <div style="background:#1a365d; border:1px solid #2b6cb0; border-radius:6px; padding:12px; margin-bottom:16px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div>
          <span class="badge draft" style="background:#2b6cb0; color:#bee3f8;">次の実装</span>
          <strong style="color:#bee3f8; margin-left:8px;">[<%= @ai_sns_plan_next["id"] %>] <%= @ai_sns_plan_next["title"] %></strong>
          <div style="color:#718096; font-size:12px; margin-top:4px;"><%= @ai_sns_plan_next["category"] %> | 優先度: <%= @ai_sns_plan_next["priority"] %></div>
          <div style="color:#a0aec0; font-size:12px; margin-top:4px;"><%= @ai_sns_plan_next["notes"] %></div>
        </div>
        <%= form_with url: admin_trigger_ai_sns_plan_path, method: :post, local: true do |f| %>
          <button type="submit" style="background:#2b6cb0; color:#fff; border:none; padding:6px 12px; border-radius:4px; cursor:pointer; font-size:12px; white-space:nowrap;">🤖 Copilot に依頼</button>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @ai_sns_plan_items %>
    <% priority_labels = { "high" => ["★★★ 高優先度", "#fc8181"], "medium" => ["★★☆ 中優先度", "#f6ad55"], "low" => ["★☆☆ 低優先度", "#a0aec0"] } %>
    <% @ai_sns_plan_items.each do |priority, items| %>
      <% next if items.empty? %>
      <% label, color = priority_labels[priority] %>
      <div style="margin-top:12px;">
        <div style="font-size:11px; color:<%= color %>; font-weight:bold; margin-bottom:4px;"><%= label %></div>
        <% items.each do |id, item| %>
          <div style="display:flex; align-items:center; padding:4px 0; border-bottom:1px solid #1a202c; font-size:12px;">
            <span style="margin-right:8px; min-width:20px;"><%= item["status"] == "done" ? "✅" : item["status"] == "in_progress" ? "🔄" : "⬜" %></span>
            <span style="color:#718096; min-width:32px; font-family:monospace;">[<%= id %>]</span>
            <span style="margin-left:6px; color:<%= item["status"] == "done" ? "#4a5568" : "#e2e8f0" %>; <%= item["status"] == "done" ? "text-decoration:line-through;" : "" %>"><%= item["title"] %></span>
            <% if item["status"] == "todo" %>
              <%= form_with url: admin_trigger_ai_sns_plan_path, method: :post, local: true, style: "margin-left:auto; padding-left:8px;" do |f| %>
                <%= f.hidden_field :item_id, value: id %>
                <button type="submit" style="background:transparent; color:#4299e1; border:1px solid #2b6cb0; padding:2px 8px; border-radius:3px; cursor:pointer; font-size:11px;">依頼</button>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
