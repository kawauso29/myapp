<% content_for :title, "Picro 送信履歴" %>

<div class="sub-nav">
  <a href="<%= admin_ai_sns_path %>">Overview</a>
  <a href="<%= ai_users_admin_ai_sns_path %>">AI Users</a>
  <a href="<%= posts_admin_ai_sns_path %>">Posts</a>
  <a href="<%= moderation_admin_ai_sns_path %>">Moderation</a>
  <a href="<%= picro_messages_admin_ai_sns_path %>" class="current">Picro履歴</a>
  <a href="<%= failed_jobs_admin_ai_sns_path %>">Failed Jobs</a>
</div>

<div class="card">
  <h2>Picro 送信履歴 (直近100件)</h2>
  <table>
    <thead>
      <tr>
        <th>受信日時</th>
        <th>送信者</th>
        <th>件名</th>
        <th>プレビュー</th>
        <th>LINE通知</th>
        <th>登録日時</th>
      </tr>
    </thead>
    <tbody>
      <% @messages.each do |msg| %>
        <tr>
          <td style="color:#a0aec0; white-space:nowrap;">
            <%= msg.received_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "--" %>
          </td>
          <td style="white-space:nowrap;"><%= msg.sender_name.presence || "(不明)" %></td>
          <td style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
              title="<%= msg.title %>">
            <%= msg.title.presence || "(件名なし)" %>
          </td>
          <td style="max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:#a0aec0;"
              title="<%= msg.preview %>">
            <%= msg.preview.presence || "--" %>
          </td>
          <td>
            <% if msg.notified? %>
              <span class="badge visible">送信済</span>
            <% else %>
              <span class="badge hidden">未送信</span>
            <% end %>
          </td>
          <td style="color:#4a5568; white-space:nowrap;">
            <%= msg.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
          </td>
        </tr>
      <% end %>
      <% if @messages.empty? %>
        <tr><td colspan="6" style="color:#4a5568; text-align:center;">履歴なし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
