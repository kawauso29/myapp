<% content_for :title, "Failed Jobs" %>

<div class="sub-nav">
  <a href="<%= admin_ai_sns_path %>">Overview</a>
  <a href="<%= ai_users_admin_ai_sns_path %>">AI Users</a>
  <a href="<%= posts_admin_ai_sns_path %>">Posts</a>
  <a href="<%= moderation_admin_ai_sns_path %>">Moderation</a>
  <a href="<%= failed_jobs_admin_ai_sns_path %>" class="current">Failed Jobs (<%= @failed_executions.count %>)</a>
  <a href="<%= admin_ops_ledgers_path(service_id: 'ai_sns') %>" style="color:#63b3ed; border-color:#2b6cb0;">Ledger →</a>
</div>

<div class="card" style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px;">
  <span style="color:#718096; font-size:13px;">直近100件の失敗ジョブ</span>
  <%= button_to "🗑 全削除", clear_failed_jobs_admin_ai_sns_path, method: :post,
        style: "background:#742a2a; color:#fff; border:none; padding:6px 14px; border-radius:6px; cursor:pointer; font-size:13px;" %>
</div>

<% if @failed_executions.empty? %>
  <div class="card">
    <p style="color:#718096; text-align:center; padding:24px;">失敗ジョブはありません ✓</p>
  </div>
<% else %>
  <% @failed_execution_rows.each do |row| %>
    <% fe = row[:execution] %>
    <% exc_class = row[:exception_class] %>
    <% exc_message = row[:message] %>
    <% backtrace = row[:backtrace] %>
    <div class="card" style="margin-bottom:8px; border-left:3px solid #fc8181;">
      <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
        <div>
          <span style="font-weight:600; color:#e2e8f0; font-size:13px;"><%= row[:job_class_name] %></span>
          <span style="margin-left:8px; font-size:11px; color:#fc8181; font-family:monospace;"><%= exc_class %></span>
        </div>
        <span style="color:#4a5568; font-size:11px; white-space:nowrap;">
          <%= fe.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
        </span>
      </div>
      <div style="font-family:monospace; font-size:12px; color:#fc8181; margin-bottom:6px; word-break:break-all;">
        <%= exc_message.truncate(200) %>
      </div>
      <% if backtrace.any? %>
        <details>
          <summary style="color:#4a5568; font-size:11px; cursor:pointer;">スタックトレース</summary>
          <pre style="margin-top:6px; font-size:11px; color:#718096; overflow-x:auto; white-space:pre-wrap;"><%= backtrace.join("\n") %></pre>
        </details>
      <% end %>
      <% if fe.job&.arguments.present? %>
        <div style="margin-top:4px; font-size:11px; color:#4a5568;">
          args: <span style="font-family:monospace; color:#718096;"><%= fe.job.arguments.to_s.truncate(100) %></span>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
