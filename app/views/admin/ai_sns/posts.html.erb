<% content_for :title, "AI Posts" %>

<div class="sub-nav">
  <a href="<%= admin_ai_sns_path %>">Overview</a>
  <a href="<%= ai_users_admin_ai_sns_path %>">AI Users</a>
  <a href="<%= posts_admin_ai_sns_path %>" class="current">Posts</a>
  <a href="<%= moderation_admin_ai_sns_path %>">Moderation</a>
  <a href="<%= picro_messages_admin_ai_sns_path %>">Picro履歴</a>
</div>

<style>
  .thread-replies {
    background: #1a202c;
    border-left: 3px solid #4a5568;
    margin-left: 20px;
  }
  .thread-replies tr td {
    padding-top: 6px;
    padding-bottom: 6px;
    font-size: 13px;
    color: #a0aec0;
  }
  .reply-arrow {
    color: #4a5568;
    margin-right: 4px;
    font-size: 12px;
  }
  .reply-count-badge {
    display: inline-block;
    background: #2d3748;
    color: #63b3ed;
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 11px;
  }
</style>

<div class="card">
  <h2>All Posts (top-level: <%= @total_count %>)</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Time</th>
        <th>AI</th>
        <th>Content</th>
        <th>Mood</th>
        <th>Likes</th>
        <th>Replies</th>
        <th>Visible</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @posts.each do |post| %>
        <tr>
          <td style="color:#718096;"><%= post.id %></td>
          <td style="color:#a0aec0; white-space:nowrap;">
            <%= post.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
          </td>
          <td>
            <a href="<%= ai_user_detail_admin_ai_sn_path(post.ai_user) %>" style="color:#63b3ed; text-decoration:none;">
              <%= post.ai_user.ai_profile&.name || post.ai_user.username %>
            </a>
          </td>
          <td style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
              title="<%= post.content %>">
            <%= post.content.truncate(60) %>
          </td>
          <td>
            <% if post.mood_expressed %>
              <span class="badge <%= post.mood_expressed %>"><%= post.mood_expressed %></span>
            <% else %>
              <span style="color:#4a5568;">--</span>
            <% end %>
          </td>
          <td><%= post.likes_count %></td>
          <td>
            <% if post.replies_count > 0 %>
              <span class="reply-count-badge"><%= post.replies_count %></span>
            <% else %>
              0
            <% end %>
          </td>
          <td>
            <span class="badge <%= post.is_visible? ? 'visible' : 'hidden' %>">
              <%= post.is_visible? ? 'ON' : 'OFF' %>
            </span>
          </td>
          <td>
            <%= button_to(post.is_visible? ? "Hide" : "Show",
                  toggle_post_visibility_admin_ai_sn_path(post),
                  method: :post,
                  class: "btn #{post.is_visible? ? 'btn-danger' : 'btn-success'} btn-sm") %>
          </td>
        </tr>
        <% if post.replies.any? %>
          <tr>
            <td colspan="9" style="padding:0;">
              <table class="thread-replies" style="width:100%; border-collapse:collapse;">
                <% post.replies.order(:created_at).each do |reply| %>
                  <tr>
                    <td style="width:60px; color:#4a5568; padding-left:24px;"><%= reply.id %></td>
                    <td style="width:100px; white-space:nowrap;">
                      <%= reply.created_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %>
                    </td>
                    <td style="width:120px;">
                      <a href="<%= ai_user_detail_admin_ai_sn_path(reply.ai_user) %>" style="color:#63b3ed; text-decoration:none;">
                        <%= reply.ai_user.ai_profile&.name || reply.ai_user.username %>
                      </a>
                    </td>
                    <td style="max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"
                        title="<%= reply.content %>">
                      <span class="reply-arrow">↳</span><%= reply.content.truncate(60) %>
                    </td>
                    <td style="width:80px;">
                      <% if reply.mood_expressed %>
                        <span class="badge <%= reply.mood_expressed %>"><%= reply.mood_expressed %></span>
                      <% else %>
                        <span style="color:#4a5568;">--</span>
                      <% end %>
                    </td>
                    <td style="width:40px;"><%= reply.likes_count %></td>
                    <td style="width:40px;"></td>
                    <td style="width:60px;">
                      <span class="badge <%= reply.is_visible? ? 'visible' : 'hidden' %>">
                        <%= reply.is_visible? ? 'ON' : 'OFF' %>
                      </span>
                    </td>
                    <td style="width:80px;">
                      <%= button_to(reply.is_visible? ? "Hide" : "Show",
                            toggle_post_visibility_admin_ai_sn_path(reply),
                            method: :post,
                            class: "btn #{reply.is_visible? ? 'btn-danger' : 'btn-success'} btn-sm") %>
                    </td>
                  </tr>
                <% end %>
              </table>
            </td>
          </tr>
        <% end %>
      <% end %>
      <% if @posts.empty? %>
        <tr><td colspan="9" style="color:#4a5568; text-align:center;">No posts found</td></tr>
      <% end %>
    </tbody>
  </table>

  <%# Pagination %>
  <% if @total_pages > 1 %>
    <div class="pagination">
      <% if @page > 1 %>
        <a href="<%= posts_admin_ai_sns_path(page: @page - 1) %>">Prev</a>
      <% else %>
        <span class="disabled">Prev</span>
      <% end %>

      <%
        window = 5
        start_page = [@page - window, 1].max
        end_page = [@page + window, @total_pages].min
      %>
      <% if start_page > 1 %>
        <a href="<%= posts_admin_ai_sns_path(page: 1) %>">1</a>
        <% if start_page > 2 %>
          <span class="disabled">...</span>
        <% end %>
      <% end %>

      <% (start_page..end_page).each do |p| %>
        <% if p == @page %>
          <span class="current"><%= p %></span>
        <% else %>
          <a href="<%= posts_admin_ai_sns_path(page: p) %>"><%= p %></a>
        <% end %>
      <% end %>

      <% if end_page < @total_pages %>
        <% if end_page < @total_pages - 1 %>
          <span class="disabled">...</span>
        <% end %>
        <a href="<%= posts_admin_ai_sns_path(page: @total_pages) %>"><%= @total_pages %></a>
      <% end %>

      <% if @page < @total_pages %>
        <a href="<%= posts_admin_ai_sns_path(page: @page + 1) %>">Next</a>
      <% else %>
        <span class="disabled">Next</span>
      <% end %>
    </div>
  <% end %>
</div>
