<% content_for :title, "Ops Audit Decisions" %>

<div class="card">
  <h2>Audit Decisions Viewer (Read Only)</h2>
  <%= form_with url: admin_ops_audit_decisions_path, method: :get, local: true do |f| %>
    <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
      <%= f.text_field :service_id, value: @service_id, placeholder: "service_id (例: ai_sns)", style: "min-width:200px; padding:6px; border-radius:6px; border:1px solid #2d3748; background:#232637; color:#e2e8f0;" %>
      <%= f.select :decision, options_for_select([ [ "(all)", "" ] ] + AuditDecisionLedger.decisions.keys.map { |k| [ k, k ] }, @decision), {}, style: "padding:6px; border-radius:6px; border:1px solid #2d3748; background:#232637; color:#e2e8f0;" %>
      <%= f.submit "Filter", class: "btn btn-primary btn-sm" %>
      <%= link_to "Reset", admin_ops_audit_decisions_path, class: "btn btn-sm", style: "background:#4a5568; color:#e2e8f0;" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h2>Decision 分布</h2>
  <table>
    <thead>
      <tr><th>decision</th><th>count</th></tr>
    </thead>
    <tbody>
      <% @decision_counts.each do |decision, count| %>
        <tr>
          <td><%= decision %></td>
          <td><%= count %></td>
        </tr>
      <% end %>
      <% if @decision_counts.empty? %>
        <tr><td colspan="2" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="card">
  <h2>Reason Code 分布</h2>
  <table>
    <thead>
      <tr><th>reason_code</th><th>count</th></tr>
    </thead>
    <tbody>
      <% @reason_code_counts.each do |code, count| %>
        <tr>
          <td><%= code %></td>
          <td><%= count %></td>
        </tr>
      <% end %>
      <% if @reason_code_counts.empty? %>
        <tr><td colspan="2" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="card">
  <h2>Non-approval 直近 10 件</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>decision</th>
        <th>reason_code</th>
        <th>audit_role</th>
        <th>target_ticket</th>
        <th>decided_at</th>
      </tr>
    </thead>
    <tbody>
      <% @non_approval_recent.each do |d| %>
        <tr>
          <td><%= d.id %></td>
          <td style="color:#f56565;"><%= d.decision %></td>
          <td><%= d.reason_code %></td>
          <td><%= d.audit_role %></td>
          <td><%= d.target_ticket_id %></td>
          <td><%= d.decided_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
      <% if @non_approval_recent.empty? %>
        <tr><td colspan="6" style="text-align:center; color:#4a5568;">該当なし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="card">
  <h2>Recent Audit Decisions (<%= @decisions.size %>)</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>decision</th>
        <th>reason_code</th>
        <th>audit_role</th>
        <th>scope</th>
        <th>service_id</th>
        <th>target_ticket</th>
        <th>decided_at</th>
      </tr>
    </thead>
    <tbody>
      <% @decisions.each do |d| %>
        <tr>
          <td><%= d.id %></td>
          <td><%= d.decision %></td>
          <td><%= d.reason_code %></td>
          <td><%= d.audit_role %></td>
          <td><%= d.scope_level %></td>
          <td><%= d.service_id.presence || "-" %></td>
          <td><%= d.target_ticket_id %></td>
          <td><%= d.decided_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
      <% if @decisions.empty? %>
        <tr><td colspan="8" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
