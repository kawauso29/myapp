<% content_for :title, "Ops Knowledge" %>

<div class="card">
  <h2>Knowledge Ledger Viewer (Read Only)</h2>
  <%= form_with url: admin_ops_knowledge_index_path, method: :get, local: true do |f| %>
    <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
      <%= f.select :kind, options_for_select([ [ "(all)", "" ] ] + KnowledgeLedger.kinds.keys.map { |k| [ k, k ] }, @kind), {}, style: "padding:6px; border-radius:6px; border:1px solid #2d3748; background:#232637; color:#e2e8f0;" %>
      <%= f.select :status, options_for_select([ [ "(all)", "" ] ] + KnowledgeLedger.statuses.keys.map { |k| [ k, k ] }, @status), {}, style: "padding:6px; border-radius:6px; border:1px solid #2d3748; background:#232637; color:#e2e8f0;" %>
      <%= f.submit "Filter", class: "btn btn-primary btn-sm" %>
      <%= link_to "Reset", admin_ops_knowledge_index_path, class: "btn btn-sm", style: "background:#4a5568; color:#e2e8f0;" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h2>Kind 分布</h2>
  <table>
    <thead><tr><th>kind</th><th>count</th></tr></thead>
    <tbody>
      <% @kind_counts.each do |kind, count| %>
        <tr><td><%= kind %></td><td><%= count %></td></tr>
      <% end %>
      <% if @kind_counts.empty? %>
        <tr><td colspan="2" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="card">
  <h2>Status 分布</h2>
  <table>
    <thead><tr><th>status</th><th>count</th></tr></thead>
    <tbody>
      <% @status_counts.each do |status, count| %>
        <tr><td><%= status %></td><td><%= count %></td></tr>
      <% end %>
      <% if @status_counts.empty? %>
        <tr><td colspan="2" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="card">
  <h2>Knowledge Records (<%= @records.size %>)</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>kind</th>
        <th>status</th>
        <th>title</th>
        <th>source_ticket</th>
        <th>supersedes</th>
        <th>created_at</th>
      </tr>
    </thead>
    <tbody>
      <% @records.each do |record| %>
        <tr>
          <td><%= record.id %></td>
          <td><%= record.kind %></td>
          <td><%= record.status %></td>
          <td><%= record.title %></td>
          <td><%= record.source_ticket_id.presence || "-" %></td>
          <td><%= record.supersedes_id.presence || "-" %></td>
          <td><%= record.created_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
      <% if @records.empty? %>
        <tr><td colspan="7" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
