<% content_for :title, "Ledger — 実行/テスト" %>
<%= render "admin/ops/ledgers/nav" %>

<% if flash[:notice] %>
  <div class="card" style="background:#1c4532; border-color:#68d391; color:#68d391; padding:10px 16px; margin-bottom:12px;"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="card" style="background:#742a2a; border-color:#fc8181; color:#fc8181; padding:10px 16px; margin-bottom:12px;"><%= flash[:alert] %></div>
<% end %>

<%# ===== SolidQueue 状態 ===== %>
<div class="card">
  <h2>SolidQueue 状態</h2>
  <div style="display:flex; gap:10px; flex-wrap:wrap;">
    <% [
      ["失敗ジョブ", @sq_stats[:failed],    @sq_stats[:failed].to_i > 0 ? "#fc8181" : "#68d391"],
      ["スケジュール済", @sq_stats[:scheduled], "#63b3ed"],
      ["直近1h実行", @sq_stats[:jobs_1h],   "#a0aec0"]
    ].each do |label, val, color| %>
      <div style="background:#1a202c; border-radius:8px; padding:12px 20px; text-align:center; min-width:120px;">
        <div style="font-size:2em; font-weight:700; color:<%= color %>;"><%= val %></div>
        <div style="font-size:0.75em; color:#718096; margin-top:4px;"><%= label %></div>
      </div>
    <% end %>
  </div>
  <div style="margin-top:12px; display:flex; gap:8px; flex-wrap:wrap;">
    <%= link_to "→ エラーログ", admin_ops_ledger_errors_path,
          style: "font-size:0.8em; background:#742a2a; color:#fc8181; padding:5px 10px; border-radius:5px; text-decoration:none;" %>
  </div>
</div>

<%# ===== Cadence ジョブ手動実行 ===== %>
<div class="card">
  <h2>Cadence ジョブ手動実行</h2>
  <p style="font-size:0.82em; color:#718096; margin-bottom:12px;">
    各 Cadence を即時 enqueue します（SolidQueue に投入）。本番の定期実行と同様に処理されます。
  </p>
  <div style="display:flex; gap:10px; flex-wrap:wrap;">
    <% @recent_cadence_jobs.each do |cfg| %>
      <%
        last_row   = cfg[:job_rows]&.first
        last_run   = last_row&.dig(:at)
        last_failed = last_row&.dig(:failed)
      %>
      <div style="background:#1a202c; border-radius:8px; padding:12px 16px; flex:1; min-width:180px; border:1px solid #2d3748;">
        <div style="font-size:0.9em; font-weight:700; color:#e2e8f0; margin-bottom:4px;"><%= cfg[:cadence] %></div>
        <div style="font-size:0.72em; color:#4a5568; font-family:monospace; margin-bottom:8px;"><%= cfg[:job_class] %></div>

        <%# 直近 10 実行 %>
        <% if cfg[:job_rows].present? %>
          <div style="display:flex; gap:2px; margin-bottom:8px;">
            <% cfg[:job_rows].each do |jr| %>
              <span title="<%= jr[:at]&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") %>" style="font-size:0.85em;"><%= jr[:failed] ? "❌" : "✅" %></span>
            <% end %>
          </div>
        <% end %>

        <div style="font-size:0.78em; color:#718096; margin-bottom:10px;">
          直近: <%= last_run ? last_run.in_time_zone("Tokyo").strftime("%m/%d %H:%M") : "なし" %>
          <% if last_failed %>
            <span style="color:#fc8181;">(失敗)</span>
          <% end %>
          | <% if cfg[:fail_count].to_i > 0 %>
            <span style="color:#fc8181; font-weight:bold;">失敗 <%= cfg[:fail_count] %></span>
          <% else %>
            失敗 0
          <% end %>
        </div>

        <%= form_with url: admin_ops_ledger_run_job_path, method: :post, local: true do |f| %>
          <%= f.hidden_field :job_class, value: cfg[:job_class] %>
          <%= f.submit "今すぐ実行", class: "btn btn-sm",
                style: "background:#2b6cb0; color:#bee3f8; font-size:0.8em; padding:4px 10px; width:100%;",
                data: { confirm: "#{cfg[:job_class]} を即時実行しますか？" } %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ===== CI/Deploy/環境変数 ===== %>
<div class="card">
  <h2>CI / Deploy / 環境変数</h2>
  <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:12px;">
    <%= form_with url: admin_sync_env_path, method: :post, local: true do |f| %>
      <%= f.submit "環境変数を同期", class: "btn btn-success btn-sm",
            data: { confirm: "本番サーバーに環境変数を同期しますか？" } %>
    <% end %>
    <%= form_with url: admin_trigger_db_snapshot_path, method: :post, local: true do |f| %>
      <%= f.submit "DBスナップショット取得",
            class: "btn btn-sm", style: "background:#4a5568; color:#e2e8f0;",
            data: { confirm: "DBスナップショットを取得しますか？" } %>
    <% end %>
  </div>
  <div style="display:flex; gap:8px; flex-wrap:wrap;">
    <% [
      ["CI 履歴", "https://github.com/kawauso29/myapp/actions/workflows/ci.yml"],
      ["Deploy 履歴", "https://github.com/kawauso29/myapp/actions/workflows/deploy.yml"],
      ["Auto Fix 履歴", "https://github.com/kawauso29/myapp/actions/workflows/auto_fix.yml"],
      ["Auto Merge", "https://github.com/kawauso29/myapp/actions/workflows/auto_merge.yml"],
      ["Weekly PDCA", "https://github.com/kawauso29/myapp/actions/workflows/weekly_pdca.yml"],
      ["AI SNS Plan", "https://github.com/kawauso29/myapp/actions/workflows/ai_sns_plan.yml"],
      ["Plan Review", "https://github.com/kawauso29/myapp/actions/workflows/plan_review.yml"],
      ["DB Snapshot", "https://github.com/kawauso29/myapp/actions/workflows/db_snapshot.yml"]
    ].each do |label, url| %>
      <%= link_to label, url, target: "_blank", rel: "noopener",
            style: "font-size:0.8em; background:#1a2744; color:#63b3ed; padding:5px 10px; border-radius:5px; text-decoration:none; border:1px solid #2b6cb0;" %>
    <% end %>
  </div>
</div>

<%# ===== その他の管理画面へのリンク ===== %>
<div class="card">
  <h2>その他の管理画面</h2>
  <div style="display:flex; gap:8px; flex-wrap:wrap;">
    <% [
      ["AI SNS管理", admin_ai_sns_path],
      ["Trading管理", admin_trading_path],
      ["承認ログ", admin_ops_ledger_approvals_path],
      ["StopLedger管理", admin_ops_stops_path],
      ["AuditDecision", admin_ops_audit_decisions_path],
      ["KnowledgeLedger", admin_ops_knowledge_index_path],
      ["Artifacts", admin_ops_artifacts_path]
    ].each do |label, path| %>
      <%= link_to label, path,
            style: "font-size:0.8em; background:#2d3748; color:#a0aec0; padding:5px 10px; border-radius:5px; text-decoration:none;" %>
    <% end %>
  </div>
</div>
