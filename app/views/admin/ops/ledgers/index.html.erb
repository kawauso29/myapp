<% content_for :title, "Ledger — 会社全体サマリ" %>
<%
  status_icon  = { healthy: "✅", late: "⚠️", stale: "🔴", missing: "❌" }
  status_color = { healthy: "#68d391", late: "#f6ad55", stale: "#fc8181", missing: "#fc8181" }

  def fmt_age(seconds)
    return "-" if seconds.nil?
    if seconds < 3600
      "#{(seconds / 60).to_i}分前"
    elsif seconds < 86400
      "#{(seconds / 3600).round(1)}時間前"
    else
      "#{(seconds / 86400).round(1)}日前"
    end
  end

  def fmt_interval(duration)
    sec = duration.to_i
    if sec < 3600;  "#{sec / 60}分"
    elsif sec < 86400; "#{sec / 3600}時間"
    else "#{sec / 86400}日"
    end
  end
%>

<%= render "admin/ops/ledgers/nav" %>

<%# ===== アラートバー ===== %>
<% if @alert_summary.present? && @alert_summary.values.any? { |v| v.to_i > 0 } %>
  <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px;">
    <% [
      [:waiting_review, "待ちレビュー", "#f6ad55"],
      [:overdue, "期限超過", "#fc8181"],
      [:non_approval, "非承認", "#f6ad55"],
      [:active_stop, "稼働停止", "#fc8181"],
      [:failed_jobs_1h, "直近1hジョブ失敗", "#fc8181"]
    ].each do |key, label, color| %>
      <% count = @alert_summary[key].to_i %>
      <div style="background:#2d3748; border-radius:6px; padding:5px 10px; display:flex; gap:6px; align-items:center; border:1px solid <%= count > 0 ? color + "88" : "#1a202c" %>;">
        <span style="font-size:1.1em; font-weight:700; color:<%= count > 0 ? color : "#4a5568" %>;"><%= count %></span>
        <span style="font-size:0.78em; color:#718096;"><%= label %></span>
      </div>
    <% end %>
    <div style="display:flex; gap:6px; align-items:center; margin-left:auto;">
      <%= link_to "承認ログ →", admin_ops_ledger_approvals_path, style: "font-size:0.8em; color:#63b3ed; text-decoration:none;" %>
      <%= link_to "エラーログ →", admin_ops_ledger_errors_path, style: "font-size:0.8em; color:#fc8181; text-decoration:none; margin-left:8px;" %>
    </div>
  </div>
<% end %>

<%# ===== 直近の主要会議 ===== %>
<div class="card">
  <h2>主要会議 — 直近実施</h2>
  <div style="display:flex; gap:10px; flex-wrap:wrap;">
    <% [
      [:annual,    "🗓 年次計画",   "#2b6cb0"],
      [:quarterly, "📊 四半期レビュー", "#276749"],
      [:monthly,   "📋 月次 Ops",  "#6b46c1"]
    ].each do |key, label, color| %>
      <% m = @last_major_meetings[key] %>
      <div style="background:#1a202c; border-radius:8px; padding:12px 16px; flex:1; min-width:200px; border:1px solid <%= color %>44;">
        <div style="font-size:0.75em; color:#718096; margin-bottom:4px;"><%= label %></div>
        <% if m %>
          <div style="font-size:0.95em; font-weight:600; color:#e2e8f0; margin-bottom:4px;">
            <%= m.held_at.in_time_zone("Tokyo").strftime("%Y/%m/%d %H:%M") %>
          </div>
          <div style="font-size:0.78em; color:#a0aec0; margin-bottom:8px;">
            status: <span style="color:<%= m.status_closed? ? "#68d391" : "#f6ad55" %>"><%= m.status %></span>
            <% if m.meeting_health_score %>
              | health: <span style="color:<%= m.meeting_health_score < 0.4 ? "#fc8181" : "#68d391" %>"><%= m.meeting_health_score.round(2) %></span>
            <% end %>
          </div>
          <%= link_to "詳細 ↗", admin_ops_ledger_path(m), style: "font-size:0.75em; color:#63b3ed; text-decoration:none;" %>
        <% else %>
          <div style="font-size:0.85em; color:#4a5568;">実施履歴なし</div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ===== 会社全体 KPI ===== %>
<div class="card">
  <h2>KPI — 全体
    <span style="font-size:0.8em; font-weight:normal; color:#718096; margin-left:8px;">(<%= @all_kpis.size %> 件)</span>
  </h2>
  <% if @all_kpis.present? %>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <% @all_kpis.each do |kpi| %>
        <%
          grade_color = { "healthy" => "#68d391", "warning" => "#f6ad55", "critical" => "#fc8181" }[kpi.grade] || "#a0aec0"
          val = kpi.current_value.is_a?(Hash) ? (kpi.current_value["value"] || "-") : kpi.current_value
        %>
        <div style="background:#1a202c; border-radius:6px; padding:10px 14px; min-width:140px; border-left:3px solid <%= grade_color %>;">
          <div style="font-size:0.7em; color:#718096; margin-bottom:2px; text-transform:uppercase;"><%= kpi.kpi_key %></div>
          <div style="font-size:1.1em; font-weight:700; color:#e2e8f0;"><%= val %></div>
          <div style="display:flex; gap:6px; margin-top:4px;">
            <span style="font-size:0.7em; color:<%= grade_color %>; font-weight:600;"><%= kpi.grade || "-" %></span>
            <span style="font-size:0.7em; color:#4a5568;"><%= kpi.scope_level %></span>
            <% if kpi.service_id.present? %>
              <span style="font-size:0.7em; color:#718096;"><%= kpi.service_id %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p style="color:#4a5568;">KPI データなし</p>
  <% end %>
</div>

<%# ===== 年次・四半期 目標 directives ===== %>
<% if @annual_directives.present? || @quarterly_directives.present? %>
  <div class="card">
    <h2>目標・指示事項</h2>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
      <div>
        <div style="font-size:0.75em; text-transform:uppercase; color:#718096; margin-bottom:6px;">📌 年次計画 directives</div>
        <% if @annual_directives.present? %>
          <% @annual_directives.first(5).each do |d| %>
            <div style="font-size:0.82em; color:#a0aec0; background:#1a202c; border-radius:4px; padding:6px 10px; margin-bottom:6px; white-space:pre-wrap; word-break:break-all;"><%= JSON.pretty_generate(d) rescue d.inspect %></div>
          <% end %>
          <% if @annual_directives.size > 5 %>
            <div style="font-size:0.75em; color:#4a5568;">… 他 <%= @annual_directives.size - 5 %> 件</div>
          <% end %>
        <% else %>
          <div style="font-size:0.82em; color:#4a5568;">データなし</div>
        <% end %>
      </div>
      <div>
        <div style="font-size:0.75em; text-transform:uppercase; color:#718096; margin-bottom:6px;">📊 四半期レビュー directives</div>
        <% if @quarterly_directives.present? %>
          <% @quarterly_directives.first(5).each do |d| %>
            <div style="font-size:0.82em; color:#a0aec0; background:#1a202c; border-radius:4px; padding:6px 10px; margin-bottom:6px; white-space:pre-wrap; word-break:break-all;"><%= JSON.pretty_generate(d) rescue d.inspect %></div>
          <% end %>
          <% if @quarterly_directives.size > 5 %>
            <div style="font-size:0.75em; color:#4a5568;">… 他 <%= @quarterly_directives.size - 5 %> 件</div>
          <% end %>
        <% else %>
          <div style="font-size:0.82em; color:#4a5568;">データなし</div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# ===== サービス別概要 ===== %>
<% if @service_overview.present? %>
  <div class="card">
    <h2>サービス別概要
      <%= link_to "→ サービス詳細", admin_ops_ledger_services_path, style: "font-size:0.8em; color:#63b3ed; text-decoration:none; margin-left:10px; font-weight:normal;" %>
    </h2>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <% Admin::Ops::LedgersController::LEDGER_SERVICES.each do |svc| %>
        <% meetings = @service_overview.dig(:meeting, svc) || 0
           tickets  = @service_overview.dig(:ticket, svc) || 0
           stops    = @service_overview.dig(:stop, svc) || 0 %>
        <div style="background:#1a202c; border-radius:8px; padding:12px 16px; flex:1; min-width:140px; border:1px solid <%= stops > 0 ? "#fc818155" : "#2d374855" %>;">
          <div style="font-weight:700; color:#e2e8f0; font-size:1.05em; margin-bottom:8px;"><%= svc %></div>
          <div style="display:flex; gap:12px; font-size:0.85em; margin-bottom:10px;">
            <div><span style="color:#718096;">会議 </span><strong><%= meetings %></strong></div>
            <div><span style="color:#718096;">Ticket </span><strong><%= tickets %></strong></div>
            <div><span style="color:<%= stops > 0 ? "#fc8181" : "#68d391" %>; font-weight:700;">Stop: <%= stops %></span></div>
          </div>
          <%= link_to "詳細 →", admin_ops_ledger_service_path(service_id: svc), style: "font-size:0.78em; color:#63b3ed; text-decoration:none;" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== Cadence 稼働状況 ===== %>
<% if @cadence_health.present? %>
  <div class="card">
    <h2>Cadence 稼働状況
      <%= link_to "→ スケジュール", admin_ops_ledger_schedule_path, style: "font-size:0.8em; color:#63b3ed; text-decoration:none; margin-left:10px; font-weight:normal;" %>
    </h2>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <% @cadence_health.each do |h| %>
        <div style="background:#1a202c; border-radius:8px; padding:10px 14px; flex:1; min-width:120px; border:1px solid <%= status_color[h[:status]] %>33;">
          <div style="font-size:0.7em; color:#718096; text-transform:uppercase; margin-bottom:2px;"><%= fmt_interval(h[:interval]) %>周期</div>
          <div style="font-size:0.95em; font-weight:700; color:#e2e8f0;"><%= h[:cadence] %></div>
          <div style="font-size:1.2em; margin:2px 0;"><%= status_icon[h[:status]] %> <span style="font-size:0.65em; color:<%= status_color[h[:status]] %>; vertical-align:middle;"><%= h[:status] %></span></div>
          <div style="font-size:0.75em; color:#a0aec0;"><%= h[:last_held_at]&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "なし" %></div>
          <div style="font-size:0.75em; color:<%= h[:fail_count].to_i > 0 ? "#fc8181" : "#4a5568" %>;">失敗 <%= h[:fail_count] %></div>
          <div style="margin-top:6px; display:flex; gap:4px;">
            <% if h[:last_id] %>
              <%= link_to "最新↗", admin_ops_ledger_path(h[:last_id]), style: "font-size:0.7em; color:#63b3ed; text-decoration:none;" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== 次の会議予定（heartbeat） ===== %>
<div class="card">
  <h2>次の会議予定（Heartbeat）
    <%= link_to "→ 全スケジュール", admin_ops_ledger_schedule_path, style: "font-size:0.8em; color:#63b3ed; text-decoration:none; margin-left:10px; font-weight:normal;" %>
  </h2>
  <% if @next_heartbeats.present? %>
    <table>
      <thead>
        <tr>
          <th>next_run_at</th>
          <th>meeting_key</th>
          <th>cycle</th>
          <th>service_id</th>
        </tr>
      </thead>
      <tbody>
        <% @next_heartbeats.each do |hb| %>
          <tr>
            <td style="color:#63b3ed;"><%= hb.next_run_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M") %></td>
            <td style="font-weight:600;"><%= hb.meeting_definition&.meeting_key || "-" %></td>
            <td style="color:#a0aec0;"><%= hb.due_cycle %></td>
            <td style="font-size:0.85em; color:#718096;"><%= hb.service_id.presence || "(全体)" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color:#4a5568;">スケジュールデータなし（ServiceHeartbeat レコードが存在しません）</p>
  <% end %>
</div>

