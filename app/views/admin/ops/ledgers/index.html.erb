<% content_for :title, "Ops Ledgers" %>

<%# ===== Ledger cadence 稼働状況 ===== %>
<% if @cadence_health.present? %>
  <%
    def cadence_age_label(seconds)
      return "-" if seconds.nil?
      if seconds < 3600
        "#{(seconds / 60).to_i}分前"
      elsif seconds < 86400
        "#{(seconds / 3600).round(1)}時間前"
      else
        "#{(seconds / 86400).round(1)}日前"
      end
    end

    def cadence_interval_label(duration)
      sec = duration.to_i
      if sec < 3600
        "#{sec / 60}分"
      elsif sec < 86400
        "#{sec / 3600}時間"
      else
        "#{sec / 86400}日"
      end
    end

    status_icon = { healthy: "✅", late: "⚠️", stale: "🔴", missing: "❌" }
    status_color = { healthy: "#68d391", late: "#f6ad55", stale: "#fc8181", missing: "#fc8181" }
    any_problem = @cadence_health.any? { |h| %i[late stale missing].include?(h[:status]) }
  %>
  <div class="card" style="<%= any_problem ? 'border-color:#f56565;' : '' %>">
    <h2 style="<%= any_problem ? 'color:#fc8181;' : 'color:#68d391;' %>">
      Ledger cadence 稼働状況
      <% if @service_id.present? %>
        <span style="font-size:0.8em; color:#a0aec0;">(service: <%= @service_id %>)</span>
      <% end %>
    </h2>
    <table>
      <thead>
        <tr>
          <th>cadence</th>
          <th>interval</th>
          <th>最終実行</th>
          <th>経過時間</th>
          <th>状態</th>
          <th>直近10周期の件数</th>
          <th>直近ジョブ（10件）成否</th>
          <th>失敗数</th>
        </tr>
      </thead>
      <tbody>
        <% @cadence_health.each do |h| %>
          <tr>
            <td style="font-weight:600; color:#e2e8f0;"><%= h[:cadence] %></td>
            <td style="color:#a0aec0;"><%= cadence_interval_label(h[:interval]) %></td>
            <td><%= h[:last_held_at]&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "-" %></td>
            <td style="color:<%= h[:age_seconds] ? (h[:age_seconds] > h[:interval].to_i * 2 ? '#f6ad55' : '#68d391') : '#fc8181' %>">
              <%= cadence_age_label(h[:age_seconds]) %>
            </td>
            <td style="color:<%= status_color[h[:status]] %>; font-weight:600;">
              <%= status_icon[h[:status]] %> <%= h[:status] %>
            </td>
            <td><%= h[:recent_count] %></td>
            <td>
              <% if h[:job_rows].empty? %>
                <span style="color:#4a5568;">記録なし</span>
              <% else %>
                <% h[:job_rows].each do |jr| %>
                  <span title="<%= jr[:at]&.in_time_zone('Tokyo')&.strftime('%m/%d %H:%M') %>">
                    <%= jr[:failed] ? "❌" : "✅" %>
                  </span>
                <% end %>
              <% end %>
            </td>
            <td style="<%= h[:fail_count] > 0 ? 'color:#fc8181; font-weight:600;' : 'color:#68d391;' %>">
              <%= h[:fail_count] %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>


<% if @alert_summary.present? %>
  <% has_alerts = @alert_summary.values.any? { |v| v.to_i > 0 } %>
  <div class="card" style="<%= has_alerts ? 'border-color:#f56565;' : '' %>">
    <h2 style="<%= has_alerts ? 'color:#fc8181;' : 'color:#68d391;' %>">
      <%= has_alerts ? '⚠ Ledger アラート' : '✅ Ledger 異常なし' %>
    </h2>
    <div class="stats-grid">
      <div class="stat <%= @alert_summary[:waiting_review].to_i > 0 ? 'yellow' : '' %>">
        <div class="value"><%= @alert_summary[:waiting_review] || 0 %></div>
        <div class="label">改善待ちレビュー</div>
      </div>
      <div class="stat <%= @alert_summary[:overdue].to_i > 0 ? 'red' : '' %>">
        <div class="value"><%= @alert_summary[:overdue] || 0 %></div>
        <div class="label">期限超過チケット</div>
      </div>
      <div class="stat <%= @alert_summary[:non_approval].to_i > 0 ? 'yellow' : '' %>">
        <div class="value"><%= @alert_summary[:non_approval] || 0 %></div>
        <div class="label">非承認（Audit）</div>
      </div>
      <div class="stat <%= @alert_summary[:active_stop].to_i > 0 ? 'red' : '' %>">
        <div class="value"><%= @alert_summary[:active_stop] || 0 %></div>
        <div class="label">稼働中の停止</div>
      </div>
    </div>
    <% if has_alerts %>
      <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;">
        <% if @alert_summary[:overdue].to_i > 0 || @alert_summary[:waiting_review].to_i > 0 %>
          <%= link_to "→ Ticket一覧", admin_ops_ledgers_path, class: "btn btn-sm", style: "background:#c05621; color:#fff;" %>
        <% end %>
        <% if @alert_summary[:non_approval].to_i > 0 %>
          <%= link_to "→ Audit Decisions", admin_ops_audit_decisions_path, class: "btn btn-sm", style: "background:#744210; color:#fff;" %>
        <% end %>
        <% if @alert_summary[:active_stop].to_i > 0 %>
          <%= link_to "→ Stops", admin_ops_stops_path, class: "btn btn-danger btn-sm" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# ===== サービス別サマリー（フィルタなし時のみ） ===== %>
<% if @service_summaries&.any? %>
  <div class="card">
    <h2>サービス別 Ledger サマリー</h2>
    <table>
      <thead>
        <tr>
          <th>service_id</th>
          <th>Meetings</th>
          <th>Tickets</th>
          <th>Active Stops</th>
          <th>フィルタ</th>
        </tr>
      </thead>
      <tbody>
        <% %w[ai_sns trading picro].each do |svc| %>
          <tr>
            <td style="font-weight:600; color:#e2e8f0;"><%= svc %></td>
            <td><%= @service_summaries.dig(:meeting, svc) || 0 %></td>
            <td><%= @service_summaries.dig(:ticket, svc) || 0 %></td>
            <td style="<%= (@service_summaries.dig(:stop, svc) || 0) > 0 ? 'color:#fc8181; font-weight:600;' : '' %>">
              <%= @service_summaries.dig(:stop, svc) || 0 %>
            </td>
            <td>
              <%= link_to "絞り込む →", admin_ops_ledgers_path(service_id: svc),
                    class: "btn btn-sm", style: "background:#2d3748; color:#e2e8f0;" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<div class="card">
  <h2>Ops Ledger Viewer (Read Only)</h2>
  <%= form_with url: admin_ops_ledgers_path, method: :get, local: true do |f| %>
    <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
      <%= f.text_field :service_id, value: @service_id, placeholder: "service_id (例: ai_sns)", style: "min-width:200px; padding:6px; border-radius:6px; border:1px solid #2d3748; background:#232637; color:#e2e8f0;" %>
      <%= f.text_field :meeting_key, value: @meeting_key, placeholder: "meeting_key (例: weekly_dept)", style: "min-width:220px; padding:6px; border-radius:6px; border:1px solid #2d3748; background:#232637; color:#e2e8f0;" %>
      <%= f.submit "Filter", class: "btn btn-primary btn-sm" %>
      <%= link_to "Reset", admin_ops_ledgers_path, class: "btn btn-sm", style: "background:#4a5568; color:#e2e8f0;" %>
      <% if @service_id == "ai_sns" %>
        <%= link_to "← AI SNS ダッシュボード", admin_ai_sns_path, class: "btn btn-sm", style: "background:#1a365d; color:#63b3ed; border:1px solid #2b6cb0;" %>
      <% elsif @service_id == "trading" %>
        <%= link_to "← Trading ダッシュボード", admin_trading_path, class: "btn btn-sm", style: "background:#1a365d; color:#63b3ed; border:1px solid #2b6cb0;" %>
      <% elsif @service_id == "picro" %>
        <%= link_to "← Picro 通知", admin_picro_notifications_path, class: "btn btn-sm", style: "background:#1a365d; color:#63b3ed; border:1px solid #2b6cb0;" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="card">
  <h2>Recent MeetingLedgers (<%= @meeting_ledgers.size %>)</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>meeting_key</th>
        <th>scope_level</th>
        <th>service_id</th>
        <th>started_at</th>
        <th>held_at</th>
        <th>finished_at</th>
        <th>status</th>
        <th>hold_items summary</th>
      </tr>
    </thead>
    <tbody>
      <% @meeting_ledgers.each do |meeting| %>
        <% hold_items = Array(meeting.hold_items) %>
        <% reason_summary = hold_items.group_by { |item| item["reason"] || item[:reason] || "unknown" }.sort.map { |reason, items| "#{reason}:#{items.count}" }.join(", ") %>
        <tr>
          <td><%= meeting.id %></td>
          <td><%= meeting.meeting_key %></td>
          <td><%= meeting.scope_level %></td>
          <td><%= meeting.service_id.presence || "-" %></td>
          <td><%= meeting.created_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
          <td><%= meeting.held_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
          <td><%= meeting.status_closed? ? (meeting.updated_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M") || "-") : "-" %></td>
          <td><%= meeting.status %></td>
          <td><%= reason_summary.presence || "none" %> (count=<%= hold_items.size %>)</td>
        </tr>
      <% end %>
      <% if @meeting_ledgers.empty? %>
        <tr><td colspan="9" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="card">
  <h2>Recent TicketLedgers (<%= @ticket_ledgers.size %>)</h2>
  <p class="ops-open-improvements">Open improvements: <strong class="ops-open-improvements-count"><%= @open_improvement_count %></strong></p>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>ticket_type</th>
        <th>service_id</th>
        <th>meeting_key</th>
        <th>status</th>
        <th>assignee</th>
        <th>due_date</th>
        <th>resolved_at</th>
        <th>escalation_to</th>
        <th>Linked KPIs</th>
      </tr>
    </thead>
    <tbody>
      <% @ticket_ledgers.each do |ticket| %>
        <% linked_kpis = ticket.linked_kpis.is_a?(Hash) ? ticket.linked_kpis.to_json : Array(ticket.linked_kpis).join(", ") %>
        <tr>
          <td><%= ticket.id %></td>
          <td>
            <% if ticket.ticket_type_improvement? %>
              <span class="ticket-type-badge-improvement">improvement</span>
            <% else %>
              <%= ticket.ticket_type %>
            <% end %>
          </td>
          <td><%= ticket.service_id.presence || "-" %></td>
          <td><%= ticket.source_meeting&.meeting_key || "-" %></td>
          <td>
            <% if ticket.status_overdue? %>
              <span style="color:#f56565; font-weight:600;">overdue</span>
            <% else %>
              <%= ticket.status %>
            <% end %>
          </td>
          <td><%= ticket.assignee.presence || "-" %></td>
          <td><%= ticket.due_date&.strftime("%Y-%m-%d") || "-" %></td>
          <td><%= ticket.resolved_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
          <td><%= ticket.escalation_to.presence || "-" %></td>
          <td><%= linked_kpis.presence || "-" %></td>
        </tr>
      <% end %>
      <% if @ticket_ledgers.empty? %>
        <tr><td colspan="10" style="text-align:center; color:#4a5568;">データなし</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
