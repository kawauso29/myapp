<% content_for :title, @meeting_key ? "Ledger: #{@meeting_key}" : "Ledger Dashboard" %>

<%
  def cadence_age_label(seconds)
    return "-" if seconds.nil?
    if seconds < 3600
      "#{(seconds / 60).to_i}分前"
    elsif seconds < 86400
      "#{(seconds / 3600).round(1)}時間前"
    else
      "#{(seconds / 86400).round(1)}日前"
    end
  end

  def cadence_interval_label(duration)
    sec = duration.to_i
    if sec < 3600
      "#{sec / 60}分"
    elsif sec < 86400
      "#{sec / 3600}時間"
    else
      "#{sec / 86400}日"
    end
  end

  status_icon  = { healthy: "✅", late: "⚠️", stale: "🔴", missing: "❌" }
  status_color = { healthy: "#68d391", late: "#f6ad55", stale: "#fc8181", missing: "#fc8181" }
%>

<%# ===== ナビゲーションバー ===== %>
<div class="card" style="padding:10px 16px;">
  <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
    <% if @meeting_key.present? %>
      <%= link_to "← Dashboard", admin_ops_ledgers_path(service_id: @service_id), class: "btn btn-sm", style: "background:#2d3748; color:#a0aec0;" %>
      <strong style="color:#e2e8f0; font-size:1.1em;"><%= @meeting_key %></strong>
      <span style="color:#718096; font-size:0.85em;">実行履歴</span>
    <% else %>
      <strong style="color:#e2e8f0; font-size:1.1em;">Ledger Dashboard</strong>
    <% end %>
    <div style="flex:1;"></div>
    <%# service_id フィルタ %>
    <%= form_with url: admin_ops_ledgers_path, method: :get, local: true do |f| %>
      <%= f.hidden_field :meeting_key, value: @meeting_key %>
      <div style="display:flex; gap:6px;">
        <%= f.text_field :service_id, value: @service_id, placeholder: "service_id", style: "width:160px; padding:5px 8px; border-radius:5px; border:1px solid #2d3748; background:#1a202c; color:#e2e8f0; font-size:0.85em;" %>
        <%= f.submit "絞込", class: "btn btn-sm", style: "background:#2d3748; color:#e2e8f0;" %>
        <%= link_to "全表示", admin_ops_ledgers_path(meeting_key: @meeting_key), class: "btn btn-sm", style: "background:#1a202c; color:#718096; border:1px solid #2d3748;" %>
      </div>
    <% end %>
    <% if @service_id == "ai_sns" %>
      <%= link_to "AI SNS ↗", admin_ai_sns_path, class: "btn btn-sm", style: "background:#1a365d; color:#63b3ed; border:1px solid #2b6cb0;" %>
    <% end %>
  </div>
</div>

<%# ===== アラートバー ===== %>
<% if @alert_summary.present? %>
  <% has_alerts = @alert_summary.values.any? { |v| v.to_i > 0 } %>
  <div style="display:flex; gap:8px; flex-wrap:wrap; padding:8px 0;">
    <div style="flex:1; display:flex; gap:8px; flex-wrap:wrap;">
      <% [
        [:waiting_review, "待ちレビュー", "#f6ad55"],
        [:overdue, "期限超過", "#fc8181"],
        [:non_approval, "非承認", "#f6ad55"],
        [:active_stop, "稼働停止", "#fc8181"]
      ].each do |key, label, color| %>
        <% count = @alert_summary[key].to_i %>
        <div style="background:#2d3748; border-radius:6px; padding:6px 12px; display:flex; gap:6px; align-items:center; <%= count > 0 ? "border:1px solid #{color};" : "border:1px solid #1a202c;" %>">
          <span style="font-size:1.1em; font-weight:700; color:<%= count > 0 ? color : "#4a5568" %>;"><%= count %></span>
          <span style="font-size:0.8em; color:#718096;"><%= label %></span>
        </div>
      <% end %>
      <% if @open_improvement_count.to_i > 0 %>
        <div style="background:#2d3748; border-radius:6px; padding:6px 12px; display:flex; gap:6px; align-items:center; border:1px solid #f6ad55;">
          <span style="font-size:1.1em; font-weight:700; color:#f6ad55;"><%= @open_improvement_count %></span>
          <span style="font-size:0.8em; color:#718096;">improvement 待ち</span>
        </div>
      <% end %>
    </div>
    <% if has_alerts %>
      <div style="display:flex; gap:6px; align-items:center; flex-wrap:wrap;">
        <% if @alert_summary[:overdue].to_i > 0 || @alert_summary[:waiting_review].to_i > 0 %>
          <%= link_to "Tickets →", admin_ops_ledgers_path, class: "btn btn-sm", style: "background:#744210; color:#f6ad55;" %>
        <% end %>
        <% if @alert_summary[:non_approval].to_i > 0 %>
          <%= link_to "Audit →", admin_ops_audit_decisions_path, class: "btn btn-sm", style: "background:#744210; color:#f6ad55;" %>
        <% end %>
        <% if @alert_summary[:active_stop].to_i > 0 %>
          <%= link_to "Stops →", admin_ops_stops_path, class: "btn btn-danger btn-sm" %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# ===== Cadence フロー図（ダッシュボードモードのみ） ===== %>
<% if @meeting_key.blank? && @cadence_health.present? %>
  <%
    cadence_node_style = ->(cadence_key) {
      h = @cadence_health.find { |c| c[:cadence].to_s == cadence_key.to_s }
      border_color = h ? (status_color[h[:status]] || "#4a5568") : "#4a5568"
      "background:#1a202c; border-radius:8px; padding:12px 14px; border:1px solid #{border_color}55; min-width:170px; flex:1;"
    }
    cadence_link = ->(meeting_key_param) {
      link_params = { meeting_key: meeting_key_param }
      link_params[:service_id] = @service_id if @service_id.present?
      admin_ops_ledgers_path(link_params)
    }
  %>
  <div class="card">
    <h2 style="margin-bottom:12px;">📊 Cadence フロー図</h2>
    <div style="font-size:0.78em; color:#718096; margin-bottom:14px;">
      daily → weekly → monthly → quarterly → annual の順に情報が集約・引き継がれます
    </div>

    <%# フロー横並び %>
    <div style="display:flex; gap:6px; align-items:stretch; overflow-x:auto; flex-wrap:wrap;">

      <%# daily %>
      <div style="<%= cadence_node_style.call(:daily) %>">
        <a href="<%= cadence_link.call("daily") %>" style="text-decoration:none;">
          <div style="font-size:0.7em; color:#718096; text-transform:uppercase; letter-spacing:0.05em;">30分周期</div>
          <div style="font-size:1.0em; font-weight:700; color:#e2e8f0; margin:2px 0;">daily</div>
          <div style="font-size:0.78em; color:#a0aec0; margin-bottom:4px;">KPIスナップショット<br>異常検知（anomaly）</div>
          <div style="font-size:0.72em; color:#4a5568;">会議なし・自動監視</div>
        </a>
      </div>

      <%# 矢印 daily → weekly %>
      <div style="display:flex; flex-direction:column; justify-content:center; align-items:center; min-width:40px; padding:0 4px;">
        <div style="font-size:1.1em; color:#63b3ed;">→</div>
        <div style="font-size:0.62em; color:#4a5568; text-align:center; line-height:1.3;">anomaly<br>carry_over</div>
      </div>

      <%# weekly %>
      <div style="<%= cadence_node_style.call(:weekly) %>">
        <a href="<%= cadence_link.call("weekly_dept") %>" style="text-decoration:none;">
          <div style="font-size:0.7em; color:#718096; text-transform:uppercase; letter-spacing:0.05em;">4時間周期</div>
          <div style="font-size:1.0em; font-weight:700; color:#e2e8f0; margin:2px 0;">weekly</div>
          <div style="font-size:0.78em; color:#a0aec0; margin-bottom:4px;">チケット起票<br>改善検知・解消</div>
          <div style="font-size:0.72em; color:#4a5568;">保留→monthly<br>エスカレーション</div>
        </a>
      </div>

      <%# 矢印 weekly → monthly %>
      <div style="display:flex; flex-direction:column; justify-content:center; align-items:center; min-width:40px; padding:0 4px;">
        <div style="font-size:1.1em; color:#63b3ed;">→</div>
        <div style="font-size:0.62em; color:#4a5568; text-align:center; line-height:1.3;">tickets<br>エスカレーション</div>
      </div>

      <%# monthly %>
      <div style="<%= cadence_node_style.call(:monthly) %>">
        <a href="<%= cadence_link.call("monthly_ops") %>" style="text-decoration:none;">
          <div style="font-size:0.7em; color:#718096; text-transform:uppercase; letter-spacing:0.05em;">12時間周期</div>
          <div style="font-size:1.0em; font-weight:700; color:#e2e8f0; margin:2px 0;">monthly</div>
          <div style="font-size:0.78em; color:#a0aec0; margin-bottom:4px;">waiting_review確定<br>改善エスカレーション</div>
          <div style="font-size:0.72em; color:#4a5568;">weekly hold_items<br>carry_over_items経由</div>
        </a>
      </div>

      <%# 矢印 monthly → quarterly %>
      <div style="display:flex; flex-direction:column; justify-content:center; align-items:center; min-width:40px; padding:0 4px;">
        <div style="font-size:1.1em; color:#63b3ed;">→</div>
        <div style="font-size:0.62em; color:#4a5568; text-align:center; line-height:1.3;">monthly<br>carry_over</div>
      </div>

      <%# quarterly %>
      <div style="<%= cadence_node_style.call(:quarterly) %>">
        <a href="<%= cadence_link.call("quarterly_review") %>" style="text-decoration:none;">
          <div style="font-size:0.7em; color:#718096; text-transform:uppercase; letter-spacing:0.05em;">2日周期</div>
          <div style="font-size:1.0em; font-weight:700; color:#e2e8f0; margin:2px 0;">quarterly</div>
          <div style="font-size:0.78em; color:#a0aec0; margin-bottom:4px;">期間集計<br>KPIサマリレビュー</div>
          <div style="font-size:0.72em; color:#4a5568;">tickets/meetings<br>集計サマリ</div>
        </a>
      </div>

      <%# 矢印 quarterly → annual %>
      <div style="display:flex; flex-direction:column; justify-content:center; align-items:center; min-width:40px; padding:0 4px;">
        <div style="font-size:1.1em; color:#63b3ed;">→</div>
        <div style="font-size:0.62em; color:#4a5568; text-align:center; line-height:1.3;">quarterly<br>carry_over</div>
      </div>

      <%# annual %>
      <div style="<%= cadence_node_style.call(:annual) %>">
        <a href="<%= cadence_link.call("annual_plan") %>" style="text-decoration:none;">
          <div style="font-size:0.7em; color:#718096; text-transform:uppercase; letter-spacing:0.05em;">7日周期</div>
          <div style="font-size:1.0em; font-weight:700; color:#e2e8f0; margin:2px 0;">annual</div>
          <div style="font-size:0.78em; color:#a0aec0; margin-bottom:4px;">年次計画<br>overdue率算出</div>
          <div style="font-size:0.72em; color:#4a5568;">全cadence集計<br>FY計画チケット</div>
        </a>
      </div>

    </div>
  </div>
<% end %>

<%# ===== Cadence ステータスカード ===== %>
<% if @cadence_health.present? %>
  <div class="card">
    <h2 style="margin-bottom:12px;">
      Cadence 稼働状況
      <% if @meeting_key.present? %>
        — <span style="color:#a0aec0;"><%= @meeting_key %></span>
      <% end %>
    </h2>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <% @cadence_health.each do |h| %>
        <%
          is_current = @meeting_key == h[:meeting_key]
          card_border = is_current ? "border:2px solid #4299e1;" : "border:1px solid #{status_color[h[:status]]}33;"
          link_params = { meeting_key: h[:meeting_key] }
          link_params[:service_id] = @service_id if @service_id.present?
        %>
        <div style="background:#1a202c; border-radius:8px; padding:12px 16px; min-width:130px; <%= card_border %> flex:1;">
          <div style="font-size:0.75em; color:#718096; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;"><%= cadence_interval_label(h[:interval]) %>周期</div>
          <div style="font-size:1.05em; font-weight:700; color:#e2e8f0; margin-bottom:2px;"><%= h[:cadence] %></div>
          <div style="font-size:1.3em; margin-bottom:4px;"><%= status_icon[h[:status]] %> <span style="font-size:0.7em; color:<%= status_color[h[:status]] %>; vertical-align:middle;"><%= h[:status] %></span></div>
          <div style="font-size:0.8em; color:#a0aec0; margin-bottom:2px;">
            最終: <%= h[:last_held_at]&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "なし" %>
          </div>
          <div style="font-size:0.8em; color:<%= h[:age_seconds] ? (h[:age_seconds] > h[:interval].to_i * 2 ? "#f6ad55" : "#68d391") : "#fc8181" %>; margin-bottom:6px;">
            <%= cadence_age_label(h[:age_seconds]) %>
          </div>
          <div style="font-size:0.75em; color:#718096; margin-bottom:8px;">
            累計 <%= h[:total_count] %> 件 |
            失敗 <span style="color:<%= h[:fail_count] > 0 ? "#fc8181" : "#68d391" %>"><%= h[:fail_count] %></span>
          </div>
          <% if h[:job_rows].present? %>
            <div style="display:flex; gap:2px; flex-wrap:wrap; margin-bottom:8px;">
              <% h[:job_rows].each do |jr| %>
                <span title="<%= jr[:at]&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") %>" style="font-size:0.9em;"><%= jr[:failed] ? "❌" : "✅" %></span>
              <% end %>
            </div>
          <% end %>
          <div style="display:flex; gap:6px;">
            <%= link_to "一覧 →", admin_ops_ledgers_path(link_params), class: "btn btn-sm", style: "background:#2d3748; color:#a0aec0; font-size:0.75em; padding:3px 8px; #{is_current ? "background:#2b6cb0; color:#bee3f8;" : ""}" %>
            <% if h[:last_id] %>
              <%= link_to "最新 ↗", admin_ops_ledger_path(h[:last_id]), class: "btn btn-sm", style: "background:#1a365d; color:#63b3ed; font-size:0.75em; padding:3px 8px;" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== KPI 状況（ダッシュボードモードのみ） ===== %>
<% if @meeting_key.blank? && @kpi_overview&.dig(:kpis)&.any? %>
  <div class="card">
    <%
      kpi_grade_color = { "healthy" => "#68d391", "warning" => "#f6ad55", "critical" => "#fc8181" }
    %>
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px; flex-wrap:wrap;">
      <h2 style="margin:0;">KPI 状況</h2>
      <div style="display:flex; gap:8px;">
        <% [["healthy", "#68d391", "✅"], ["warning", "#f6ad55", "⚠️"], ["critical", "#fc8181", "🔴"]].each do |grade, color, icon| %>
          <% count = @kpi_overview[:"#{grade}_count"].to_i %>
          <span style="font-size:0.82em; padding:3px 8px; border-radius:12px; background:#1a202c; border:1px solid <%= color %>33; color:<%= count > 0 ? color : "#4a5568" %>;">
            <%= icon %> <%= grade %> <%= count %>
          </span>
        <% end %>
        <% if @kpi_overview[:uncollected_count].to_i > 0 %>
          <span style="font-size:0.82em; padding:3px 8px; border-radius:12px; background:#1a202c; border:1px solid #4a556888; color:#718096;">
            ⬜ 未収集 <%= @kpi_overview[:uncollected_count] %>
          </span>
        <% end %>
      </div>
      <% if @kpi_overview[:uncollected_count].to_i > 0 %>
        <span style="font-size:0.78em; color:#718096; font-style:italic;">※ KPI値が未収集です。Ops画面から「KPI 自動収集」を実行してください</span>
      <% end %>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <% @kpi_overview[:kpis].each do |kpi| %>
        <%
          gcolor = kpi_grade_color[kpi.grade] || "#718096"
          val    = kpi.current_value.is_a?(Hash) ? kpi.current_value["value"] : kpi.current_value
          tgt    = kpi.numeric_target_value
        %>
        <div style="background:#1a202c; border-radius:6px; padding:10px 14px; min-width:145px; border-left:3px solid <%= gcolor %>; flex:1;">
          <div style="font-size:0.68em; color:#4a5568; margin-bottom:2px; font-family:monospace; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= kpi.kpi_key %>"><%= kpi.kpi_key.sub("kpi:", "") %></div>
          <div style="font-size:0.7em; color:#718096; margin-bottom:4px;"><%= kpi.service_id.presence || "company" %></div>
          <% if val.present? %>
            <div style="font-size:1.3em; font-weight:700; color:<%= gcolor %>;"><%= val.is_a?(Float) ? val.round(1) : val %></div>
          <% else %>
            <div style="font-size:1.1em; color:#4a5568; font-style:italic;">未収集</div>
          <% end %>
          <div style="font-size:0.73em; color:#4a5568; margin-top:2px;">目標: <%= tgt&.to_s || "-" %> <%= kpi.current_value.is_a?(Hash) ? kpi.current_value["unit"].to_s : "" %></div>
          <div style="font-size:0.7em; margin-top:4px;">
            <span style="color:<%= gcolor %>; font-weight:600;"><%= kpi.grade || "未評価" %></span>
            <% if kpi.graded_at %>
              <span style="color:#4a5568; margin-left:6px;"><%= kpi.graded_at.in_time_zone("Tokyo").strftime("%m/%d") %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== PDCA フロー（ダッシュボードモードのみ） ===== %>
<% if @meeting_key.blank? && @pdca_summary.present? %>
  <div class="card">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px; flex-wrap:wrap;">
      <h2 style="margin:0;">PDCA フロー</h2>
      <div style="font-size:0.78em; color:#718096;">KPI 未達 → 検知 → 改善チケット → GitHub Issue → Copilot 実装</div>
    </div>

    <%# ループ診断パネル %>
    <%
      kpi_collected   = @pdca_summary[:last_kpi_collect].present?
      kpi_recent      = kpi_collected && @pdca_summary[:last_kpi_collect] > 36.hours.ago
      has_warning_kpi = @kpi_overview.present? && (@kpi_overview[:warning_count].to_i + @kpi_overview[:critical_count].to_i) > 0
      has_tickets     = @pdca_summary[:total_improvement].to_i > 0
      planner_ran     = @pdca_summary[:last_planner_run].present?
      last_daily_at   = @pdca_summary[:last_daily_run]
      daily_recent    = last_daily_at.present? && last_daily_at > 2.hours.ago

      # ループが止まっている箇所を特定
      loop_steps = [
        {
          id: :kpi_collect,
          label: "① KPI 収集",
          ok: kpi_collected && kpi_recent,
          detail: kpi_collected ? "最終: #{@pdca_summary[:last_kpi_collect].in_time_zone("Tokyo").strftime("%m/%d %H:%M")}" : "未実行",
          fix: "Ops画面「KPI自動収集」を実行 または KpiAutoCollectJob（20:30 UTC 毎日）を確認"
        },
        {
          id: :daily_runner,
          label: "② Daily Runner",
          ok: daily_recent,
          detail: last_daily_at ? "最終: #{last_daily_at.in_time_zone("Tokyo").strftime("%m/%d %H:%M")}" : "未実行",
          fix: "SolidQueue scheduler が停止している可能性。Ops画面「Daily Runner」を手動実行、またはPumaを再起動"
        },
        {
          id: :kpi_grade,
          label: "③ KPI グレード評価",
          ok: has_warning_kpi,
          detail: has_warning_kpi ? "warning/critical あり" : "全KPI healthy または未評価",
          fix: "KPI値が収集されていれば自動評価される。Ops画面「KPIグレード評価」を実行"
        },
        {
          id: :ticket,
          label: "④ チケット起票",
          ok: has_tickets,
          detail: has_tickets ? "#{@pdca_summary[:total_improvement]}件" : "起票なし",
          fix: "Planner が未起票。KPIが warning/critical になっていること、ImprovementDetectorJob/PlannerJobを確認"
        },
        {
          id: :planner,
          label: "⑤ Planner実行",
          ok: planner_ran,
          detail: planner_ran ? "最終: #{@pdca_summary[:last_planner_run].in_time_zone("Tokyo").strftime("%m/%d %H:%M")}" : "未実行",
          fix: "Ops画面「Planner（改善起票）」を実行"
        }
      ]
      first_broken = loop_steps.find { |s| !s[:ok] }
    %>

    <%# ステップ状態表示 %>
    <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:14px; align-items:stretch;">
      <% loop_steps.each_with_index do |step, i| %>
        <% ok = step[:ok] %>
        <div style="background:#1a202c; border-radius:6px; padding:8px 12px; border:1px solid <%= ok ? "#68d39133" : "#fc818133" %>; flex:1; min-width:120px;">
          <div style="font-size:0.7em; color:#4a5568; margin-bottom:2px;"><%= step[:label] %></div>
          <div style="font-size:1.1em;"><%= ok ? "✅" : "❌" %></div>
          <div style="font-size:0.72em; color:#718096; margin-top:2px;"><%= step[:detail] %></div>
        </div>
        <% if i < loop_steps.size - 1 %>
          <div style="display:flex; align-items:center; color:#4a5568; font-size:0.9em; padding:0 2px;">→</div>
        <% end %>
      <% end %>
    </div>

    <%# 止まっている箇所の案内 %>
    <% if first_broken %>
      <div style="background:#2d1515; border-radius:6px; padding:10px 14px; margin-bottom:14px; border-left:3px solid #fc8181;">
        <div style="font-size:0.82em; color:#fc8181; font-weight:600; margin-bottom:4px;">
          🔴 ループ停滞: <%= first_broken[:label] %> で止まっています
        </div>
        <div style="font-size:0.82em; color:#a0aec0;">
          対処: <%= first_broken[:fix] %>
        </div>
      </div>
    <% else %>
      <div style="background:#1a2d1a; border-radius:6px; padding:8px 14px; margin-bottom:14px; border-left:3px solid #68d391;">
        <span style="font-size:0.82em; color:#68d391; font-weight:600;">✅ ループは正常に動作しています</span>
      </div>
    <% end %>

    <%# パイプラインサマリ %>
    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:14px;">
      <% [
        ["改善チケット 合計", @pdca_summary[:total_improvement], "#a0aec0"],
        ["待ちレビュー", @pdca_summary[:waiting_review], "#f6ad55"],
        ["承認済み", @pdca_summary[:approved], "#68d391"],
        ["30日完了", @pdca_summary[:completed_30d], "#63b3ed"]
      ].each do |label, count, color| %>
        <div style="background:#1a202c; border-radius:6px; padding:8px 14px; min-width:90px; text-align:center; border:1px solid #2d374855;">
          <div style="font-size:1.5em; font-weight:700; color:<%= color %>;"><%= count %></div>
          <div style="font-size:0.72em; color:#718096; margin-top:2px;"><%= label %></div>
        </div>
      <% end %>
    </div>

    <%# 最終実行情報 %>
    <div style="display:flex; gap:12px; margin-bottom:14px; font-size:0.78em; color:#718096; flex-wrap:wrap;">
      <span>
        KPI収集: <%= @pdca_summary[:last_kpi_collect] ? @pdca_summary[:last_kpi_collect].in_time_zone("Tokyo").strftime("%m/%d %H:%M") : "未実行" %>
        <% if @pdca_summary[:last_kpi_collect].nil? %>
          <span style="color:#f6ad55; margin-left:4px;">← まず Ops 画面から「KPI 自動収集」を実行してください</span>
        <% end %>
      </span>
      <span>Planner: <%= @pdca_summary[:last_planner_run] ? @pdca_summary[:last_planner_run].in_time_zone("Tokyo").strftime("%m/%d %H:%M") : "未実行" %></span>
    </div>

    <%# 直近の改善チケット %>
    <% if @pdca_summary[:recent_tickets].present? %>
      <table>
        <thead>
          <tr>
            <th>チケット</th>
            <th>ステータス</th>
            <th>担当</th>
            <th>KPI</th>
            <th>期限</th>
          </tr>
        </thead>
        <tbody>
          <% @pdca_summary[:recent_tickets].each do |t| %>
            <tr>
              <td style="font-size:0.82em; max-width:240px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= t.title %>"><%= t.title %></td>
              <td>
                <% sc = { "waiting_review" => "#f6ad55", "approved" => "#68d391", "completed" => "#63b3ed", "overdue" => "#fc8181" }[t.status] || "#a0aec0" %>
                <span style="color:<%= sc %>; font-size:0.82em;"><%= t.status %></span>
              </td>
              <td style="font-size:0.78em; color:#718096;"><%= t.assignee.presence || "-" %></td>
              <td style="font-size:0.75em; color:#4a5568; max-width:120px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                <%= Array(t.linked_kpis).join(", ") %>
              </td>
              <td style="font-size:0.78em; color:<%= t.due_date && t.due_date < Date.current ? "#fc8181" : "#718096" %>"><%= t.due_date&.strftime("%m/%d") || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div style="margin-top:8px; font-size:0.78em;">
        <%= link_to "全チケット →", admin_ops_ledgers_path(meeting_key: "weekly_dept"), style: "color:#63b3ed; text-decoration:none;" %>
        <%= link_to "Ops（手動実行）→", admin_ops_ledger_operations_path, style: "color:#63b3ed; text-decoration:none; margin-left:12px;" %>
      </div>
    <% else %>
      <p style="color:#4a5568; font-size:0.85em;">
        改善チケットなし —
        KPI が収集され grade が warning/critical になると Planner が自動起票します
      </p>
    <% end %>
  </div>
<% end %>

<%# ===== サービス別概要（ダッシュボードモードのみ） ===== %>
<% if @service_overview&.any? %>
  <div class="card">
    <h2>サービス別概要</h2>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <% Admin::Ops::LedgersController::LEDGER_SERVICES.each do |svc| %>
        <% meetings = @service_overview.dig(:meeting, svc) || 0
           tickets  = @service_overview.dig(:ticket, svc) || 0
           stops    = @service_overview.dig(:stop, svc) || 0 %>
        <div style="background:#1a202c; border-radius:8px; padding:12px 16px; flex:1; min-width:140px; border:1px solid <%= stops > 0 ? "#fc818155" : "#2d374855" %>;">
          <div style="font-weight:700; color:#e2e8f0; font-size:1.05em; margin-bottom:8px;"><%= svc %></div>
          <div style="display:flex; gap:12px; font-size:0.85em; margin-bottom:10px;">
            <div><span style="color:#718096;">Meetings </span><strong style="color:#e2e8f0;"><%= meetings %></strong></div>
            <div><span style="color:#718096;">Tickets </span><strong style="color:#e2e8f0;"><%= tickets %></strong></div>
            <div><span style="color:#718096;">Stops </span><strong style="color:<%= stops > 0 ? "#fc8181" : "#68d391" %>; font-weight:700;"><%= stops %></strong></div>
          </div>
          <%= link_to "詳細 →", admin_ops_ledgers_path(service_id: svc), class: "btn btn-sm", style: "background:#2d3748; color:#a0aec0; font-size:0.75em;" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ===== 実行履歴テーブル ===== %>
<% if @meeting_key.present? && defined?(@meeting_ledgers) %>
  <%# cadence 詳細モード %>
  <div class="card">
    <h2>
      <%= @meeting_key %> 実行履歴
      <span style="font-size:0.75em; color:#718096; font-weight:normal; margin-left:8px;">（直近 <%= @meeting_ledgers.size %> 件）</span>
      <% if @service_id.present? %>
        <span style="font-size:0.75em; color:#a0aec0; font-weight:normal;"> / service: <%= @service_id %></span>
      <% end %>
    </h2>
    <% if @meeting_key == "daily" %>
      <div style="margin-bottom:10px; padding:8px 12px; background:#1a202c; border-radius:6px; border-left:3px solid #4a5568; font-size:0.8em; color:#718096;">
        📊 <strong style="color:#a0aec0;">監視モード（30分毎自動実行）</strong>
        — このcadenceはKPIスナップショット取得・異常検知のみを行います。<br>
        チケット起票はしません。KPI が critical になった場合に hold_items が増加し、weekly cadence に引き継がれます。
      </div>
    <% end %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>held_at</th>
          <th>service_id</th>
          <th>status</th>
          <th>hold_items</th>
          <th>carry_over</th>
          <th>health</th>
          <th>詳細</th>
        </tr>
      </thead>
      <tbody>
        <% @meeting_ledgers.each do |m| %>
          <% hold_items = Array(m.hold_items)
             carry = Array(m.carry_over_items)
             anomaly_count = hold_items.count { |i| (i["type"] || i[:type]).to_s == "anomaly" } %>
          <tr>
            <td style="color:#718096;"><%= m.id %></td>
            <td><%= m.held_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "-" %></td>
            <td><%= m.service_id.presence || "-" %></td>
            <td>
              <span style="color:<%= m.status_closed? ? "#68d391" : "#f6ad55" %>; font-size:0.85em;"><%= m.status %></span>
            </td>
            <td>
              <% if hold_items.empty? %>
                <span style="color:#4a5568;">0</span>
              <% else %>
                <span style="color:<%= anomaly_count > 0 ? "#fc8181" : "#f6ad55" %>; font-weight:600;"><%= hold_items.size %></span>
                <% if anomaly_count > 0 %>
                  <span style="font-size:0.75em; color:#fc8181;"> (異常 <%= anomaly_count %>)</span>
                <% end %>
              <% end %>
            </td>
            <td style="color:#718096;"><%= carry.size %></td>
            <td>
              <% if m.meeting_health_score %>
                <span style="color:<%= m.meeting_health_score < 0.4 ? "#fc8181" : "#68d391" %>; font-size:0.85em;"><%= m.meeting_health_score.round(2) %></span>
              <% else %>
                <span style="color:#4a5568;">-</span>
              <% end %>
            </td>
            <td>
              <%= link_to "詳細 ↗", admin_ops_ledger_path(m), class: "btn btn-sm", style: "background:#1a365d; color:#63b3ed; font-size:0.75em; padding:3px 8px;" %>
            </td>
          </tr>
        <% end %>
        <% if @meeting_ledgers.empty? %>
          <tr><td colspan="8" style="text-align:center; color:#4a5568; padding:20px;">データなし</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# cadence 詳細: 関連チケット %>
  <% if defined?(@ticket_ledgers) && @ticket_ledgers.present? %>
    <div class="card">
      <h2>
        関連チケット
        <span style="font-size:0.75em; color:#718096; font-weight:normal; margin-left:8px;">（<%= @ticket_ledgers.size %> 件）</span>
        <span style="font-size:0.75em; color:#a0aec0; font-weight:normal; margin-left:4px;">Open improvements: <%= @open_improvement_count %></span>
      </h2>
      <table data-testid="ticket-ledger-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>ticket_type</th>
            <th>service_id</th>
            <th>status</th>
            <th>assignee</th>
            <th>due_date</th>
            <th>resolved_at</th>
          </tr>
        </thead>
        <tbody>
          <% @ticket_ledgers.each do |t| %>
            <tr>
              <td style="color:#718096;"><%= t.id %></td>
              <td>
                <% if t.ticket_type_improvement? %>
                  <span class="ticket-type-badge-improvement">improvement</span>
                <% else %>
                  <span style="font-size:0.85em;"><%= t.ticket_type %></span>
                <% end %>
              </td>
              <td><%= t.service_id.presence || "-" %></td>
              <td>
                <% if t.status_overdue? %>
                  <span style="color:#f56565; font-weight:600;">overdue</span>
                <% elsif t.status_waiting_review? %>
                  <span style="color:#f6ad55;">waiting_review</span>
                <% else %>
                  <span style="color:#a0aec0; font-size:0.85em;"><%= t.status %></span>
                <% end %>
              </td>
              <td style="font-size:0.85em;"><%= t.assignee.presence || "-" %></td>
              <td style="font-size:0.85em;"><%= t.due_date&.strftime("%m/%d") || "-" %></td>
              <td style="font-size:0.85em;"><%= t.resolved_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

<% else %>
  <%# ダッシュボードモード: 最新実行ログ %>
  <% if defined?(@recent_runs) && @recent_runs.present? %>
    <div class="card">
      <h2>
        最近の実行
        <span style="font-size:0.75em; color:#718096; font-weight:normal; margin-left:8px;">（全cadence 直近 <%= @recent_runs.size %> 件）</span>
      </h2>
      <table>
        <thead>
          <tr>
            <th>cadence</th>
            <th>held_at</th>
            <th>service_id</th>
            <th>status</th>
            <th>hold_items</th>
            <th>詳細</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_runs.each do |m| %>
            <% hold_items = Array(m.hold_items)
               anomaly_count = hold_items.count { |i| (i["type"] || i[:type]).to_s == "anomaly" }
               is_monitoring = m.meeting_key == "daily" %>
            <tr>
              <td>
                <%= link_to m.meeting_key, admin_ops_ledgers_path(meeting_key: m.meeting_key, service_id: @service_id), style: "color:#63b3ed; font-weight:600;" %>
                <% if is_monitoring %>
                  <span style="font-size:0.7em; background:#1a202c; color:#718096; padding:1px 5px; border-radius:8px; margin-left:4px; border:1px solid #2d3748;" title="KPIスナップショット取得のみ。アクション不要です">📊 監視</span>
                <% end %>
              </td>
              <td><%= m.held_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M") || "-" %></td>
              <td style="font-size:0.85em; color:#a0aec0;"><%= m.service_id.presence || "-" %></td>
              <td>
                <span style="color:<%= m.status_closed? ? "#68d391" : "#f6ad55" %>; font-size:0.85em;"><%= m.status %></span>
              </td>
              <td>
                <% if hold_items.empty? %>
                  <span style="color:#4a5568;">0</span>
                <% else %>
                  <span style="color:<%= anomaly_count > 0 ? "#fc8181" : "#f6ad55" %>; font-weight:600;"><%= hold_items.size %></span>
                  <% if anomaly_count > 0 %>
                    <span style="font-size:0.75em; color:#fc8181;"> (異常 <%= anomaly_count %>)</span>
                  <% end %>
                <% end %>
              </td>
              <td>
                <%= link_to "↗", admin_ops_ledger_path(m), class: "btn btn-sm", style: "background:#1a365d; color:#63b3ed; font-size:0.75em; padding:3px 8px;" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
