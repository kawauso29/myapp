<% content_for :title, "Ledger ##{@meeting.id}" %>
<%= render "admin/ops/ledgers/nav" %>

<%
  def cadence_interval_label(duration)
    sec = duration.to_i
    if sec < 3600
      "#{sec / 60}分"
    elsif sec < 86400
      "#{sec / 3600}時間"
    else
      "#{sec / 86400}日"
    end
  end

  status_color_show = { healthy: "#68d391", late: "#f6ad55", stale: "#fc8181", missing: "#fc8181" }
%>

<%# ===== ナビ ===== %>
<div class="card" style="padding:10px 16px;">
  <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
    <%= link_to "← #{@meeting.meeting_key} 一覧", admin_ops_ledgers_path(meeting_key: @meeting.meeting_key, service_id: @meeting.service_id), class: "btn btn-sm", style: "background:#2d3748; color:#a0aec0;" %>
    <%= link_to "← Dashboard", admin_ops_ledgers_path, class: "btn btn-sm", style: "background:#1a202c; color:#718096; border:1px solid #2d3748;" %>
    <strong style="color:#e2e8f0;">Meeting #<%= @meeting.id %></strong>
    <span style="color:#718096; font-size:0.9em;"><%= @meeting.meeting_key %></span>
    <% if @meeting.service_id.present? %>
      <span style="color:#a0aec0; font-size:0.85em;">/ <%= @meeting.service_id %></span>
    <% end %>
  </div>
</div>

<%# ===== 基本情報 ===== %>
<div class="card">
  <h2>基本情報</h2>
  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:12px;">
    <% [
      ["meeting_key",  @meeting.meeting_key],
      ["meeting_type", @meeting.meeting_type],
      ["scope_level",  @meeting.scope_level],
      ["service_id",   @meeting.service_id.presence || "-"],
      ["held_at",      @meeting.held_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M:%S") || "-"],
      ["status",       @meeting.status],
      ["chair",        @meeting.chair],
      ["duration_min", @meeting.duration_minutes&.to_s || "-"],
    ].each do |label, val| %>
      <div style="background:#1a202c; border-radius:6px; padding:10px;">
        <div style="font-size:0.75em; color:#718096; margin-bottom:2px;"><%= label %></div>
        <div style="color:#e2e8f0; font-weight:600; word-break:break-all;"><%= val %></div>
      </div>
    <% end %>
    <% if @meeting.meeting_health_score %>
      <div style="background:#1a202c; border-radius:6px; padding:10px; border:1px solid <%= @meeting.unhealthy? ? "#fc8181" : "#68d391" %>55;">
        <div style="font-size:0.75em; color:#718096; margin-bottom:2px;">health_score</div>
        <div style="color:<%= @meeting.unhealthy? ? "#fc8181" : "#68d391" %>; font-weight:700; font-size:1.2em;"><%= @meeting.meeting_health_score.round(3) %></div>
      </div>
    <% end %>
  </div>
  <% if @meeting.idempotency_key.present? %>
    <div style="margin-top:10px; font-size:0.8em; color:#4a5568;">
      idempotency_key: <code style="color:#718096;"><%= @meeting.idempotency_key %></code>
    </div>
  <% end %>
</div>

<%# ===== SolidQueue ジョブ情報 ===== %>
<% if @job_row %>
  <div class="card" style="border-color:<%= @job_row[:failed] ? "#fc8181" : "#68d391" %>55;">
    <h2>SolidQueue ジョブ</h2>
    <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap;">
      <div style="font-size:1.5em;"><%= @job_row[:failed] ? "❌ 失敗" : "✅ 成功" %></div>
      <div style="font-size:0.85em; color:#a0aec0;">
        job_id: <%= @job_row[:job].id %><br>
        class: <%= @job_row[:job].class_name %><br>
        finished_at: <%= @job_row[:job].finished_at&.in_time_zone("Tokyo")&.strftime("%Y-%m-%d %H:%M:%S") %>
      </div>
    </div>
  </div>
<% end %>

<%# ===== KPI スナップショット（daily の decisions から） ===== %>
<% decisions = Array(@meeting.decisions)
   kpi_snapshot = decisions.flat_map { |d| Array(d["kpi_snapshot"] || d[:kpi_snapshot]) }.compact %>
<% if kpi_snapshot.present? %>
  <div class="card">
    <h2>KPI スナップショット（<%= kpi_snapshot.size %> 件）</h2>
    <table>
      <thead>
        <tr>
          <th>kpi_key</th>
          <th>current_value</th>
          <th>grade</th>
        </tr>
      </thead>
      <tbody>
        <% kpi_snapshot.each do |kpi| %>
          <% grade = kpi["grade"] || kpi[:grade]
             val   = kpi["current_value"] || kpi[:current_value]
             key   = kpi["kpi_key"] || kpi[:kpi_key] %>
          <tr>
            <td><%= key %></td>
            <td><%= val %></td>
            <td style="color:<%= grade == "critical" ? "#fc8181" : grade == "warning" ? "#f6ad55" : "#68d391" %>; font-weight:600;"><%= grade || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% anomaly_count = decisions.map { |d| d["anomaly_count"] || d[:anomaly_count] }.compact.sum %>
    <% if anomaly_count > 0 %>
      <p style="color:#fc8181; margin-top:8px; font-weight:600;">⚠️ 異常検知: <%= anomaly_count %> 件</p>
    <% end %>
  </div>
<% end %>

<%# ===== hold_items ===== %>
<% hold_items = Array(@meeting.hold_items) %>
<% if hold_items.present? %>
  <div class="card" style="border-color:#f6ad5533;">
    <h2>hold_items（<%= hold_items.size %> 件）</h2>
    <% grouped = hold_items.group_by { |i| i["type"] || i[:type] || i["reason"] || i[:reason] || "unknown" } %>
    <% grouped.each do |group_key, items| %>
      <%
        is_anomaly    = group_key.to_s == "anomaly"
        group_label   = AdminOpsLedgersHelper::LEDGER_HOLD_REASON_LABELS[group_key.to_s] || group_key.to_s
        header_color  = is_anomaly ? "#fc8181" : "#f6ad55"
      %>
      <h3 style="color:<%= header_color %>; font-size:0.9em; margin:10px 0 6px;">
        <%= group_label %> (<%= items.size %>)
      </h3>
      <table>
        <tbody>
          <% items.each do |item| %>
            <tr>
              <% clean = item.reject { |k, _| %w[type reason].include?(k.to_s) } %>
              <% clean.each do |k, v| %>
                <%
                  field_label = case k.to_s
                                when "kpi_key"          then "KPI"
                                when "missing_kpi_keys" then "未定義KPI"
                                when "next_cycle"       then "次cadence"
                                when "title"            then "タイトル"
                                when "grade"            then "グレード"
                                else k.to_s
                                end
                  display_v = v.is_a?(Array) ? v.join(", ") : v
                %>
                <td style="color:#718096; font-size:0.8em; white-space:nowrap;"><%= field_label %></td>
                <td style="font-size:0.85em; color:<%= k.to_s == "grade" && v.to_s == "critical" ? "#fc8181" : "#e2e8f0" %>; padding-right:16px;"><%= display_v %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
<% else %>
  <div class="card">
    <h2>hold_items</h2>
    <p style="color:#4a5568;">なし（異常・保留なし）</p>
  </div>
<% end %>

<%# ===== carry_over_items ===== %>
<% carry = Array(@meeting.carry_over_items) %>
<% if carry.present? %>
  <div class="card">
    <h2 style="color:#a0aec0;">carry_over_items（<%= carry.size %> 件、前回からの引き継ぎ）</h2>
    <% carry.first(10).each do |item| %>
      <%
        item_type   = (item["type"]       || item[:type]       || item["reason"] || item[:reason]).to_s
        kpi_key     = item["kpi_key"]     || item[:kpi_key]
        grade       = item["grade"]       || item[:grade]
        title       = item["title"]       || item[:title]
        reason      = item["reason"]      || item[:reason]
        next_cycle  = item["next_cycle"]  || item[:next_cycle]
        miss_keys   = item["missing_kpi_keys"] || item[:missing_kpi_keys]
        reason_label = AdminOpsLedgersHelper::LEDGER_HOLD_REASON_LABELS[item_type] ||
                       AdminOpsLedgersHelper::LEDGER_HOLD_REASON_LABELS[reason.to_s] ||
                       item_type
        grade_color  = AdminOpsLedgersHelper::LEDGER_GRADE_COLOR[grade.to_s] || "#718096"
      %>
      <div style="background:#1a202c; border-radius:6px; padding:8px 12px; margin-bottom:6px; border-left:3px solid <%= item_type == "anomaly" ? "#fc8181" : "#4a5568" %>;">
        <div style="font-size:0.82em; font-weight:600; color:<%= item_type == "anomaly" ? "#fc8181" : "#f6ad55" %>; margin-bottom:4px;">
          <%= reason_label %>
        </div>
        <% if kpi_key.present? %>
          <div style="font-size:0.8em; color:#a0aec0; margin-bottom:2px;">
            KPI: <code style="color:#63b3ed;"><%= kpi_key %></code>
            <% if grade.present? %>
              <span style="margin-left:8px; padding:1px 6px; border-radius:10px; background:<%= grade_color %>22; color:<%= grade_color %>; font-size:0.85em;"><%= grade %></span>
            <% end %>
          </div>
        <% end %>
        <% if miss_keys.present? %>
          <div style="font-size:0.8em; color:#f6ad55; margin-bottom:2px;">
            未定義KPI: <%= Array(miss_keys).join(", ") %>
          </div>
        <% end %>
        <% if title.present? %>
          <div style="font-size:0.8em; color:#e2e8f0; margin-bottom:2px;"><%= title %></div>
        <% end %>
        <% if next_cycle.present? %>
          <div style="font-size:0.75em; color:#718096;">→ 次cadence: <strong><%= next_cycle %></strong> に引き継ぎ</div>
        <% end %>
      </div>
    <% end %>
    <% if carry.size > 10 %>
      <p style="color:#4a5568; font-size:0.8em;">... 他 <%= carry.size - 10 %> 件</p>
    <% end %>
  </div>
<% end %>

<%# ===== directives ===== %>
<% directives = Array(@meeting.directives).reject(&:blank?) %>
<% if directives.present? %>
  <div class="card">
    <h2>directives</h2>
    <% directives.each do |d| %>
      <% d_sym = d.is_a?(Hash) ? d.transform_keys(&:to_s) : {} %>
      <% if d_sym["improvements"].present? %>
        <% imp = d_sym["improvements"].is_a?(Hash) ? d_sym["improvements"].transform_keys(&:to_s) : {} %>
        <div style="background:#1a202c; border-radius:6px; padding:10px 14px; margin-bottom:8px;">
          <div style="font-size:0.82em; font-weight:600; color:#a0aec0; margin-bottom:6px;">🔧 improvements</div>
          <div style="display:flex; gap:12px; margin-bottom:8px; flex-wrap:wrap;">
            <div style="background:#2d3748; border-radius:6px; padding:6px 12px; text-align:center;">
              <div style="font-size:1.3em; font-weight:700; color:<%= imp["detected"].to_i > 0 ? "#f6ad55" : "#68d391" %>;"><%= imp["detected"] || 0 %></div>
              <div style="font-size:0.72em; color:#718096;">検知</div>
            </div>
            <div style="background:#2d3748; border-radius:6px; padding:6px 12px; text-align:center;">
              <div style="font-size:1.3em; font-weight:700; color:#68d391;"><%= imp["resolved"] || 0 %></div>
              <div style="font-size:0.72em; color:#718096;">解消</div>
            </div>
          </div>
          <% details = Array(imp["details"]).compact %>
          <% if details.present? %>
            <table>
              <thead>
                <tr>
                  <th style="font-size:0.75em;">ルール</th>
                  <th style="font-size:0.75em;">タイトル</th>
                  <th style="font-size:0.75em;">チケットID</th>
                </tr>
              </thead>
              <tbody>
                <% details.each do |det| %>
                  <% det_s = det.is_a?(Hash) ? det.transform_keys(&:to_s) : {} %>
                  <tr>
                    <td style="font-size:0.8em; color:#718096;"><%= det_s["rule"] || det_s["operation"] || "-" %></td>
                    <td style="font-size:0.8em; color:#e2e8f0; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= det_s["title"] %>"><%= det_s["title"] || "-" %></td>
                    <td style="font-size:0.8em; color:#63b3ed;"><%= det_s["ticket_id"] || "-" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% end %>
        </div>
      <% elsif d_sym["daily_summary"] %>
        <div style="background:#1a202c; border-radius:6px; padding:8px 12px; margin-bottom:6px; font-size:0.82em; color:#a0aec0;">
          📊 日次サマリ
          <% if d_sym["kpi_count"].present? %>
            <span style="margin-left:8px; color:#63b3ed;">KPI <%= d_sym["kpi_count"] %> 件</span>
          <% end %>
        </div>
      <% else %>
        <div style="font-size:0.85em; color:#a0aec0; background:#1a202c; border-radius:4px; padding:8px; margin-bottom:6px; white-space:pre-wrap; word-break:break-all;"><%= JSON.pretty_generate(d) rescue d.inspect %></div>
      <% end %>
    <% end %>
  </div>
<% end %>

<%# ===== daily → weekly 引き継ぎパネル ===== %>
<% if @meeting.meeting_type_daily? && hold_items.any? { |i| (i["type"] || i[:type]).to_s == "anomaly" } %>
  <% anomaly_count = hold_items.count { |i| (i["type"] || i[:type]).to_s == "anomaly" } %>
  <div class="card" style="border-color:#4299e133;">
    <h2 style="color:#63b3ed;">🔗 daily → weekly 引き継ぎ</h2>
    <p style="font-size:0.88em; color:#a0aec0; margin-bottom:10px;">
      この daily の <strong style="color:#fc8181;">異常 <%= anomaly_count %> 件</strong> は次の weekly cadence に引き継がれ、チケット起票の対象になります。
    </p>
    <% if @next_weekly_meeting %>
      <div style="background:#1a365d; border-radius:6px; padding:8px 12px; display:inline-flex; gap:12px; align-items:center;">
        <span style="font-size:0.85em; color:#a0aec0;">次の weekly:</span>
        <%= link_to "Meeting ##{@next_weekly_meeting.id} （#{@next_weekly_meeting.held_at&.in_time_zone("Tokyo")&.strftime("%m/%d %H:%M")}）→",
              admin_ops_ledger_path(@next_weekly_meeting),
              style: "color:#63b3ed; font-weight:600; text-decoration:none;" %>
      </div>
    <% else %>
      <div style="font-size:0.85em; color:#4a5568; font-style:italic;">まだ次の weekly は実行されていません</div>
    <% end %>
  </div>
<% end %>

<%# ===== 関連チケット ===== %>
<div class="card">
  <h2>
    関連チケット
    <% if @related_tickets.present? %>
      <span style="font-size:0.75em; color:#718096; font-weight:normal; margin-left:8px;"><%= @related_tickets.size %> 件</span>
    <% end %>
  </h2>
  <% if @related_tickets.empty? %>
    <p style="color:#4a5568;">チケットなし</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>ticket_type</th>
          <th>service_id</th>
          <th>status</th>
          <th>assignee</th>
          <th>due_date</th>
          <th>linked_kpis</th>
        </tr>
      </thead>
      <tbody>
        <% @related_tickets.each do |t| %>
          <tr>
            <td style="color:#718096;"><%= t.id %></td>
            <td>
              <% if t.ticket_type_improvement? %>
                <span class="ticket-type-badge-improvement">improvement</span>
              <% else %>
                <span style="font-size:0.85em;"><%= t.ticket_type %></span>
              <% end %>
            </td>
            <td style="font-size:0.85em;"><%= t.service_id.presence || "-" %></td>
            <td>
              <% if t.status_overdue? %>
                <span style="color:#f56565; font-weight:600;">overdue</span>
              <% elsif t.status_waiting_review? %>
                <span style="color:#f6ad55;">waiting_review</span>
              <% else %>
                <span style="color:#a0aec0; font-size:0.85em;"><%= t.status %></span>
              <% end %>
            </td>
            <td style="font-size:0.85em;"><%= t.assignee.presence || "-" %></td>
            <td style="font-size:0.85em;"><%= t.due_date&.strftime("%m/%d") || "-" %></td>
            <td style="font-size:0.8em; color:#718096; word-break:break-all;">
              <% kpis = t.linked_kpis %>
              <% if kpis.is_a?(Hash) %>
                <% kpis.first(3).each do |k, v| %><%= k %>: <%= v %><br><% end %>
              <% else %>
                <%= Array(kpis).first(3).join(", ") %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
