<%
  current_action = controller.action_name
  tabs = [
    { key: "index",            label: "🏢 会社サマリ",  path: admin_ops_ledgers_path },
    { key: "services",         label: "📦 サービス",      path: admin_ops_ledger_services_path },
    { key: "schedule",         label: "📅 スケジュール",  path: admin_ops_ledger_schedule_path },
    { key: "departments",      label: "👥 各部",          path: admin_ops_ledger_departments_path },
    { key: "approvals",        label: "✅ 承認ログ",       path: admin_ops_ledger_approvals_path },
    { key: "errors",           label: "🚨 エラーログ",    path: admin_ops_ledger_errors_path },
    { key: "operations",       label: "⚙️ 実行/テスト",  path: admin_ops_ledger_operations_path }
  ]
  service_tab_actions = %w[services service_detail]
  dept_tab_actions    = %w[departments department_detail]
%>
<div style="background:#151823; border-bottom:1px solid #2d3748; padding:0 16px; margin-bottom:16px; overflow-x:auto; white-space:nowrap;">
  <% tabs.each do |tab| %>
    <%
      is_active = if tab[:key] == "services"
                    service_tab_actions.include?(current_action)
                  elsif tab[:key] == "departments"
                    dept_tab_actions.include?(current_action)
                  else
                    current_action == tab[:key]
                  end
    %>
    <%= link_to tab[:label], tab[:path],
          style: "display:inline-block; padding:10px 14px; font-size:0.82em; font-weight:600; text-decoration:none; border-bottom:2px solid #{is_active ? '#4299e1' : 'transparent'}; color:#{is_active ? '#63b3ed' : '#718096'}; margin-right:2px;" %>
  <% end %>
</div>
