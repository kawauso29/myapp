<div id="terminal-container"></div>

<script>
(function() {
  var statusBar = document.getElementById('status-bar');

  var term = new Terminal({
    cursorBlink: true,
    fontSize: 14,
    fontFamily: "Menlo, Monaco, 'Courier New', monospace",
    theme: { background: '#1a1a1a', foreground: '#d4d4d4', cursor: '#d4d4d4' },
    scrollback: 5000,
    convertEol: false,
  });

  var container = document.getElementById('terminal-container');
  term.open(container);

  function fitTerminal() {
    var rect = container.getBoundingClientRect();
    var charW = term._core._renderService.dimensions.css.cell.width  || 8.4;
    var charH = term._core._renderService.dimensions.css.cell.height || 17;
    var cols = Math.max(10, Math.floor((rect.width  - 12) / charW));
    var rows = Math.max(5,  Math.floor((rect.height - 12) / charH));
    term.resize(cols, rows);
    return { rows: rows, cols: cols };
  }

  setTimeout(fitTerminal, 100);

  // ActionCable WebSocket protocol
  var proto      = location.protocol === 'https:' ? 'wss' : 'ws';
  var ws         = new WebSocket(proto + '://' + location.host + '/cable');
  var identifier = JSON.stringify({ channel: 'ClaudeChannel' });
  var subscribed = false;

  function sendToChannel(action, payload) {
    if (!subscribed || ws.readyState !== 1) return;
    ws.send(JSON.stringify({
      command:    'message',
      identifier: identifier,
      data:       JSON.stringify(Object.assign({ action: action }, payload)),
    }));
  }

  ws.onopen = function() {
    ws.send(JSON.stringify({ command: 'subscribe', identifier: identifier }));
  };

  ws.onclose = function() {
    statusBar.textContent = '● disconnected';
    statusBar.style.color = '#f44';
    term.write('\r\n\x1b[31m[Connection closed]\x1b[0m\r\n');
  };

  ws.onerror = function() {
    statusBar.textContent = '● error';
    statusBar.style.color = '#f44';
    term.write('\r\n\x1b[31m[WebSocket error]\x1b[0m\r\n');
  };

  ws.onmessage = function(event) {
    var msg;
    try { msg = JSON.parse(event.data); } catch(e) { return; }

    if (msg.type === 'welcome' || msg.type === 'ping') return;

    if (msg.type === 'confirm_subscription') {
      subscribed = true;
      statusBar.textContent = '● claude';
      statusBar.style.color = '#4caf50';
      var size = fitTerminal();
      sendToChannel('resize', size);
      term.focus();
      return;
    }

    if (msg.type === 'reject_subscription') {
      term.write('\x1b[31m[Auth failed]\x1b[0m\r\n');
      return;
    }

    if (msg.message) {
      var m = msg.message;
      if (m.type === 'output') {
        term.write(m.data);
      } else if (m.type === 'exit') {
        statusBar.textContent = '● exited';
        statusBar.style.color = '#ff9800';
        term.write('\r\n\x1b[33m[Session ended]\x1b[0m\r\n');
      } else if (m.type === 'error') {
        term.write('\r\n\x1b[31m[Error: ' + m.message + ']\x1b[0m\r\n');
      }
    }
  };

  term.onData(function(data) {
    statusBar.textContent = '● claude [sending]';
    sendToChannel('input', { text: data });
    setTimeout(function() { statusBar.textContent = '● claude'; }, 300);
  });

  window.addEventListener('resize', function() {
    var size = fitTerminal();
    sendToChannel('resize', size);
  });
})();
</script>
