<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>AI Admin</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
           background: #0f1117; color: #e2e8f0; font-size: 14px; }

    /* ナビ */
    nav { background: #1a1d2e; border-bottom: 1px solid #2d3748; padding: 10px 24px;
          display: flex; align-items: center; gap: 0; flex-wrap: wrap; }
    nav .logo { font-size: 16px; font-weight: 700; color: #63b3ed; margin-right: 20px; }
    nav a { color: #a0aec0; text-decoration: none; font-size: 13px; padding: 4px 10px; border-radius: 4px; }
    nav a:hover { color: #e2e8f0; background: #232637; }
    nav a.active { color: #63b3ed; font-weight: 600; background: #1a2744; }

    /* ナビグループ */
    .nav-divider { width: 1px; height: 20px; background: #2d3748; margin: 0 8px; flex-shrink: 0; }

    /* メインコンテンツ */
    main { padding: 24px; max-width: 1400px; margin: 0 auto; }

    /* カード */
    .card { background: #1a1d2e; border: 1px solid #2d3748; border-radius: 8px;
             padding: 16px; margin-bottom: 16px; }
    .card h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em;
                color: #718096; margin-bottom: 12px; }

    /* 統計グリッド */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; }
    .stat { background: #1a1d2e; border: 1px solid #2d3748; border-radius: 8px;
             padding: 16px; text-align: center; }
    .stat .value { font-size: 28px; font-weight: 700; }
    .stat .label { font-size: 12px; color: #718096; margin-top: 4px; }
    .stat.green .value { color: #68d391; }
    .stat.red   .value { color: #fc8181; }
    .stat.blue  .value { color: #63b3ed; }
    .stat.yellow .value { color: #f6e05e; }

    /* テーブル */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 8px 12px; color: #718096; font-weight: 600;
         border-bottom: 1px solid #2d3748; font-size: 12px; text-transform: uppercase; }
    td { padding: 8px 12px; border-bottom: 1px solid #1e2433; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #232637; }

    /* バッジ */
    .badge { display: inline-block; padding: 2px 8px; border-radius: 12px;
              font-size: 11px; font-weight: 600; }
    .badge.bull     { background: #1c4532; color: #68d391; }
    .badge.bear     { background: #4a1942; color: #fc8181; }
    .badge.ranging  { background: #1a365d; color: #63b3ed; }
    .badge.dangerous { background: #4a1942; color: #fc8181; }
    .badge.execute  { background: #1c4532; color: #68d391; }
    .badge.skip     { background: #2d3748; color: #a0aec0; }
    .badge.buy      { background: #1c4532; color: #68d391; }
    .badge.sell     { background: #4a1942; color: #fc8181; }
    .badge.win      { background: #1c4532; color: #68d391; }
    .badge.loss     { background: #4a1942; color: #fc8181; }
    .badge.veto     { background: #4a1942; color: #fc8181; }
    .badge.draft    { background: #2d4a1e; color: #9ae6b4; }

    /* 2カラムグリッド */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* エージェントカード */
    .agents-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; }
    .agent-card { background: #232637; border-radius: 6px; padding: 12px; }
    .agent-card .name { font-size: 12px; color: #718096; margin-bottom: 8px; }
    .agent-card .judgment { font-size: 18px; font-weight: 700; }
    .agent-card .confidence { font-size: 12px; color: #a0aec0; margin-top: 4px; }
    .agent-card .veto-flag { font-size: 11px; color: #fc8181; margin-top: 4px; }

    /* 市場状態パネル */
    .market-panel { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px; }
    .market-item .label { font-size: 11px; color: #718096; }
    .market-item .value { font-size: 16px; font-weight: 600; margin-top: 2px; }

    /* 損益 */
    .pnl.positive { color: #68d391; }
    .pnl.negative { color: #fc8181; }

    /* 共通バッジ */
    .badge.active   { background: #1c4532; color: #68d391; }
    .badge.inactive { background: #4a1942; color: #fc8181; }
    .badge.seed     { background: #1a365d; color: #63b3ed; }
    .badge.positive { background: #1c4532; color: #68d391; }
    .badge.neutral  { background: #2d3748; color: #a0aec0; }
    .badge.negative { background: #4a1942; color: #fc8181; }
    .badge.visible  { background: #1c4532; color: #68d391; }
    .badge.hidden   { background: #4a1942; color: #fc8181; }
    .badge.warning  { background: #5a3e1b; color: #f6e05e; }
    .badge.info     { background: #1a365d; color: #63b3ed; }

    /* ボタン */
    .btn { display: inline-block; padding: 6px 14px; border-radius: 6px;
           font-size: 12px; font-weight: 600; text-decoration: none;
           cursor: pointer; border: none; transition: opacity 0.2s; }
    .btn:hover { opacity: 0.85; }
    .btn-primary { background: #3182ce; color: #fff; }
    .btn-danger  { background: #e53e3e; color: #fff; }
    .btn-success { background: #38a169; color: #fff; }
    .btn-sm { padding: 4px 10px; font-size: 11px; }

    /* サブナビ */
    .sub-nav { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .sub-nav a { display: inline-block; padding: 6px 16px; border-radius: 6px;
                 background: #232637; color: #a0aec0; text-decoration: none;
                 font-size: 13px; font-weight: 500; border: 1px solid #2d3748; }
    .sub-nav a:hover { background: #2d3748; color: #e2e8f0; }
    .sub-nav a.current { background: #3182ce; color: #fff; border-color: #3182ce; }

    /* プロフィールカード */
    .profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 13px; }
    .profile-grid dt { color: #718096; }
    .profile-grid dd { color: #e2e8f0; margin: 0; }

    /* ページネーション */
    .pagination { display: flex; gap: 8px; margin-top: 16px; justify-content: center; }
    .pagination a, .pagination span { display: inline-block; padding: 4px 12px;
      border-radius: 4px; font-size: 13px; text-decoration: none;
      border: 1px solid #2d3748; color: #a0aec0; }
    .pagination a:hover { background: #2d3748; color: #e2e8f0; }
    .pagination .current { background: #3182ce; color: #fff; border-color: #3182ce; }
    .pagination .disabled { color: #4a5568; cursor: default; }

    /* フラッシュメッセージ */
    .flash { padding: 10px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 13px; }
    .flash.notice { background: #1c4532; color: #68d391; border: 1px solid #276749; }
    .flash.alert  { background: #4a1942; color: #fc8181; border: 1px solid #742a2a; }

    @media (max-width: 768px) { .grid-2 { grid-template-columns: 1fr; } }

    /* フッター */
    footer { margin-top: 48px; border-top: 1px solid #2d3748; padding: 24px;
             max-width: 1400px; margin-left: auto; margin-right: auto; }
    .url-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
    .url-section h3 { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;
                      color: #4a5568; margin-bottom: 10px; font-weight: 700; }
    .url-list { list-style: none; }
    .url-list li { margin-bottom: 6px; display: flex; align-items: baseline; gap: 8px; }
    .url-list a { color: #63b3ed; text-decoration: none; font-size: 13px; font-family: monospace; }
    .url-list a:hover { color: #90cdf4; text-decoration: underline; }
    .url-list .method { font-size: 10px; font-weight: 700; padding: 1px 5px; border-radius: 3px;
                        font-family: monospace; flex-shrink: 0; }
    .method.get    { background: #1a365d; color: #63b3ed; }
    .method.post   { background: #276749; color: #68d391; }
    .method.delete { background: #742a2a; color: #fc8181; }
    .url-list .note { font-size: 11px; color: #4a5568; }
  </style>
</head>
<body>
  <nav>
    <span class="logo">Admin</span>

    <a href="<%= admin_root_path %>" class="<%= 'active' if controller_path == 'admin/repository' %>">Repository</a>

    <span class="nav-divider"></span>

    <%# ===== 独立系統 ===== %>
    <a href="<%= admin_picro_notifications_path %>" class="<%= 'active' if controller_path == 'admin/picro_notifications' %>">Picro</a>

    <span class="nav-divider"></span>

    <a href="<%= admin_linestamp_root_path %>" class="<%= 'active' if controller_path.start_with?('admin/linestamp') %>">Linestamp</a>
  </nav>
  <main>
    <% if flash[:notice] %>
      <div class="flash notice"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="flash alert"><%= flash[:alert] %></div>
    <% end %>
    <%= yield %>
  </main>

  <footer>
    <div class="url-grid">

      <div class="url-section">
        <h3>管理画面</h3>
        <ul class="url-list">
          <li><a href="/admin">/admin</a> <span class="note">Repository Dashboard</span></li>
          <li><a href="/admin/picro_notifications">/admin/picro_notifications</a> <span class="note">Picro通知管理</span></li>
          <li><a href="/admin/linestamp">/admin/linestamp</a> <span class="note">Linestamp管理</span></li>
        </ul>
      </div>

      <div class="url-section">
        <h3>接続情報</h3>
        <ul class="url-list">
          <li><a href="http://133.167.124.112">http://133.167.124.112</a> <span class="note">本番サーバー</span></li>
          <li><span class="note" style="font-family:monospace; color:#a0aec0;">ws://133.167.124.112/cable</span> <span class="note">WebSocket</span></li>
          <li><span class="note" style="font-family:monospace; color:#a0aec0;">localhost:3000</span> <span class="note">開発環境</span></li>
        </ul>
      </div>

    </div>
  </footer>
</body>
</html>
