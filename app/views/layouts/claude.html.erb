<!DOCTYPE html>
<html>
  <head>
    <title>Claude Terminal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.min.css">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; background: #1a1a1a; overflow: hidden; }
      #terminal-container { width: 100%; height: 100vh; padding: 6px; }
      #status-bar {
        position: fixed; top: 4px; right: 8px;
        padding: 2px 8px; font-size: 12px;
        font-family: monospace; color: #aaa; z-index: 100;
        background: rgba(0,0,0,0.5); border-radius: 3px;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.min.js"></script>
  </head>
  <body>
    <div id="status-bar">connecting...</div>
    <%= yield %>
  </body>
</html>
