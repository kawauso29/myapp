#!/bin/bash
# VPS cron から weekly_pdca.yml を workflow_dispatch で起動するスクリプト
# GitHub schedule トリガーの遅延・スキップ対策として VPS cron から直接 dispatch する
#
# crontab 設定例 (deploy.yml の Setup VPS cron jobs で自動登録):
#   */10 * * * * $HOME/myapp/bin/dispatch_weekly_pdca >> /tmp/weekly_pdca_cron.log 2>&1
#
# 必要な権限: DEPLOY_TOKEN に Actions: Read and Write スコープが必要
#
# ログ: /tmp/weekly_pdca_cron.log に出力
#   - ログローテーション: 1000行を超えたら古い行を自動削除

set -a
# shellcheck source=/dev/null
source "$HOME/myapp/.env"
set +a

REPO="kawauso29/myapp"
WORKFLOW="weekly_pdca.yml"
LOG_FILE="/tmp/weekly_pdca_cron.log"

# ログローテーション（1000行を超えたら最新500行のみ残す）
if [ -f "$LOG_FILE" ] && [ "$(wc -l < "$LOG_FILE")" -gt 1000 ]; then
  tail -500 "$LOG_FILE" > "${LOG_FILE}.tmp" && mv "${LOG_FILE}.tmp" "$LOG_FILE"
fi

if [ -z "$DEPLOY_TOKEN" ]; then
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] ERROR: DEPLOY_TOKEN が未設定です"
  exit 1
fi

RESPONSE=$(curl -s -o /tmp/dispatch_response.json -w "%{http_code}" \
  -X POST \
  -H "Authorization: Bearer $DEPLOY_TOKEN" \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  "https://api.github.com/repos/${REPO}/actions/workflows/${WORKFLOW}/dispatches" \
  -d '{"ref":"main"}')

if [ "$RESPONSE" = "204" ]; then
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] OK: ${WORKFLOW} を dispatch しました (HTTP $RESPONSE)"
else
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] ERROR: dispatch 失敗 (HTTP $RESPONSE)"
  cat /tmp/dispatch_response.json 2>/dev/null || true
  exit 1
fi
