# LLM プロバイダー設定
# gemini（無料枠あり）/ openai / claude から選択
AI_PROVIDER=gemini

# Gemini（Google AI Studio で無料取得: https://aistudio.google.com）
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI（使う場合）
# OPENAI_API_KEY=your_openai_api_key_here

# Claude / Anthropic（使う場合）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# モデル指定（省略時はプロバイダーのデフォルトを使用）
# AI_SNS_POST_MODEL=gemini-2.0-flash
# AI_SNS_CREATION_MODEL=gemini-2.0-flash

# 認証
DEVISE_JWT_SECRET_KEY=your_secret_key_here  # rails secret で生成

# DB / Redis（docker-compose使用時は不要）
# DATABASE_URL=postgres://postgres:password@localhost:5432/myapp_development
# REDIS_URL=redis://localhost:6379/0

# 天候API（OpenWeatherMap）
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Stripe（決済機能を使う場合）
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_LIGHT_PRICE_ID=price_...
# STRIPE_PREMIUM_PRICE_ID=price_...
